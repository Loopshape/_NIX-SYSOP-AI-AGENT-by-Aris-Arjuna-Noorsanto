# ============ ENHANCED CONSENSUS ENGINE ============
class EnhancedConsensusEngine:
    """Extended consensus engine with mathematical optimizations and Qbit-Map fractal logic"""
    
    def __init__(self, db_connection):
        self.db = db_connection
    
    def calculate_entropy(self, text: str) -> float:
        """Calculate Shannon entropy of text"""
        if not text:
            return 0
        
        char_freq = {}
        for char in text:
            char_freq[char] = char_freq.get(char, 0) + 1
        
        entropy = 0
        text_len = len(text)
        
        for count in char_freq.values():
            p = count / text_len
            entropy -= p * math.log2(p)
        
        return entropy

    def _run_fractal_consensus(self, initial_entropy: float, bounce_depth: int, avg_entropy: float) -> float:
        """
        Qbit-Map Iteration: Applies recursive fractal transformation to a model's entropy score.
        This simulates iterative consensus refinement in a complex solution space.
        
        Iteration: Z(n+1) = Z(n)^2 + C
        Z(0) = initial_entropy (real part, 0 imaginary)
        C = Complexity Constant (avg_entropy + 0.1i)
        
        Returns the final magnitude of the complex number after iterations.
        """
        # Ensure initial_entropy is a positive non-zero value for stable iteration
        z = cmath.complex(max(initial_entropy, 0.001), 0.0)
        
        # Define a Complexity Constant C based on global context
        c_real = avg_entropy if avg_entropy > 0.001 else 1.0
        C = cmath.complex(c_real, 0.1 * math.pi)

        # Run recursive iteration (bounce)
        for _ in range(bounce_depth):
            z = z * z + C
            # Simple boundary check to prevent overflow
            if abs(z) > 1000:
                 return 0.0 # Diverged

        return abs(z)

    def mathematical_optimize(self, scored_outputs: List[Tuple[float, str]], use_qbit: bool, bounce_depth: int) -> str:
        """
        Selects the best output using raw scoring or the Qbit-Map fractal consensus.
        scored_outputs: List of (raw_entropy, output_text)
        """
        if not scored_outputs:
            return ""

        if not use_qbit:
            # Fallback to standard entropy scoring
            scored_outputs.sort(key=lambda x: x[0], reverse=True)
            return scored_outputs[0][1]

        print_info(f"Applying Qbit-Map Consensus (Bounce Depth: {bounce_depth})")
        
        # 1. Calculate Average Entropy for the Complexity Constant C
        total_entropy = sum(raw_entropy for raw_entropy, _ in scored_outputs)
        avg_entropy = total_entropy / len(scored_outputs) if scored_outputs else 1.0

        fractal_scores = []
        for raw_entropy, output_text in scored_outputs:
            # 2. Run Fractal Iteration
            fractal_score = self._run_fractal_consensus(raw_entropy, bounce_depth, avg_entropy)
            
            # 3. Combine Fractal Score with Code Quality (Bonus Score)
            code_blocks = len(re.findall(r'```[\s\S]*?```', output_text))
            bonus_score = code_blocks * 10
            
            final_score = fractal_score + bonus_score
            fractal_scores.append((final_score, output_text))

        # 4. Return highest scored output
        fractal_scores.sort(key=lambda x: x[0], reverse=True)

        if fractal_scores[0][0] == 0:
            print_warning("Qbit-Map result diverged or scored zero. Falling back to simple score.")
            scored_outputs.sort(key=lambda x: x[0], reverse=True)
            return scored_outputs[0][1]

        print_debug(f"Highest Fractal Score: {fractal_scores[0][0]:.4f}")
        return fractal_scores[0][1]
    
    async def parallel_model_consensus(self, prompt: str, models: List[str], max_iterations: int = 2, use_qbit: bool = False, bounce_depth: int = 3) -> Dict[str, Any]:
        """Run models in parallel and reach consensus using specified scoring method."""
        all_outputs = [] # List of raw output strings
        
        for iteration in range(max_iterations):
            print_info(f"Consensus iteration {iteration + 1}/{max_iterations}")
            
            # Run all models in parallel
            tasks = [run_ollama_model_async(model, prompt) for model in models]
            results = await asyncio.gather(*tasks, return_exceptions=True)
            
            valid_outputs = [r for r in results if isinstance(r, str) and not r.startswith('[ERROR')]
            all_outputs.extend(valid_outputs)
            
            if len(valid_outputs) >= len(models) * 0.6:  # 60% success rate
                break
        
        # Score outputs using entropy
        scored_outputs = []
        for output in all_outputs:
            entropy = self.calculate_entropy(output)
            scored_outputs.append((entropy, output))

        # Mathematical optimization of results (Fractal or standard)
        best_output = self.mathematical_optimize(scored_outputs, use_qbit, bounce_depth)
        
        return {
            'output': best_output,
            'total_models': len(models),
            'successful_runs': len([o for e, o in scored_outputs if o]),
            'consensus_score': len(all_outputs) / (len(models) * max_iterations)
        }

