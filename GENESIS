# ============ SAFE WRITE HELPERS ============
def is_under_repo(path: str) -> bool:
    """Check if path is within safe repository boundaries"""
    try:
        path_obj = Path(path).resolve()
        repo_obj = Path(REPO).resolve()
        return repo_obj in path_obj.parents or path_obj == repo_obj
    except Exception:
        return False

def require_confirmation_for(path: str) -> bool:
    """Return True if path requires explicit confirmation (outside safe repo)"""
    return not is_under_repo(path)

def interactive_confirm(action_description: str, path: str) -> bool:
    """Interactive confirmation for unsafe operations"""
    phrase = f"CONFIRM-WRITE:{Path(path).resolve()}"
    
    print(f"\n{Colors.style('*** AGENT NEMODIAN - SAFETY GATE ***', Colors.YELLOW, True)}")
    print(f"{Colors.style('Action:', Colors.BOLD)} {action_description}")
    print(f"{Colors.style('Target:', Colors.BOLD)} {path}")
    print(f"{Colors.style('WARNING: This path is outside safe directory (~/_).', Colors.RED, True)}")
    print(f"{Colors.style('To proceed, type this exact phrase:', Colors.BOLD)}")
    print(f"{Colors.style(f'>>> {phrase}', Colors.GREEN, True)}")
    
    try:
        user_input = input().strip()
    except (EOFError, KeyboardInterrupt):
        user_input = ""
    
    if user_input == phrase:
        print_success("Confirmation accepted - proceeding with write operation")
        return True
    
    print_error("Confirmation failed - operation cancelled")
    return False

def safe_write_file(path: str, data: bytes, mode: str = "wb") -> bool:
    """Safely write file with boundary checks"""
    if require_confirmation_for(path):
        if not interactive_confirm("Write file", path):
            return False
    
    directory = os.path.dirname(path) or "."
    os.makedirs(directory, exist_ok=True)
    
    try:
        with open(path, mode) as f:
            f.write(data if isinstance(data, (bytes, str)) else str(data).encode())
        return True
    except Exception as e:
        print_error(f"Failed to write {path}: {e}")
        return False

def safe_execute_script(script_path: str) -> bool:
    """Safely execute script with boundary checks"""
    if require_confirmation_for(script_path):
        if not interactive_confirm("Execute script", script_path):
            return False
    
    try:
        result = subprocess.run([script_path], capture_output=True, text=True, check=True)
        print_success(f"Script executed: {script_path}")
        if result.stdout:
            print_debug(f"Output: {result.stdout}")
        return True
    except Exception as e:
        print_error(f"Script execution failed: {e}")
        return False

# ============ EXTENDED SOURCE LOADER ============
def load_extended_source(src: str) -> bytes:
    """Enhanced source loader with regex patterns and special handlers"""
    
    # Handle mathematical calculations
    if src.startswith(('calc:', 'math:')):
        try:
            expr = src.split(':', 1)[1].strip()
            # Safe math evaluation
            math_env = {
                'math': math, 'sin': math.sin, 'cos': math.cos, 'tan': math.tan,
                'log': math.log, 'exp': math.exp, 'sqrt': math.sqrt,
                'pi': math.pi, 'e': math.e, 'tau': math.tau
            }
            result = eval(expr, {"__builtins__": {}}, math_env)
            return f"{expr} = {result}".encode()
        except Exception as e:
            return f"Calculation error: {e}".encode()
    
    # Handle regex file patterns
    if 'regex/' in src or any(pattern in src for pattern in ['/*', '/?', '.*']):
        pattern = src.replace('regex/', '').replace('/*', '*').replace('/?', '?').replace('.*', '*')
        matches = list(Path(REPO).rglob(pattern))
        if matches:
            content = b''
            for match in matches[:10]:  # Limit results
                if match.is_file():
                    content += f"\n=== FILE: {match} ===\n".encode()
                    try:
                        content += match.read_bytes()
                    except Exception:
                        content += b"[Unable to read file]"
            return content if content else b"No files matched pattern"
    
    # Handle search operations
    if src.startswith('search:'):
        query = src[7:].strip().lower()
        results = []
        for root, dirs, files in os.walk(REPO):
            for file in files:
                if file.endswith(('.py', '.js', '.html', '.css', '.md', '.txt', '.json')):
                    filepath = os.path.join(root, file)
                    try:
                        with open(filepath, 'r', encoding='utf-8', errors='ignore') as f:
                            content = f.read()
                            if query in content.lower():
                                # Find context around match
                                lines = content.split('\n')
                                for i, line in enumerate(lines):
                                    if query in line.lower():
                                        context = '\n'.join(lines[max(0, i-1):min(len(lines), i+2)])
                                        results.append(f"{filepath} (line {i+1}):\n{context}\n")
                                        break
                    except Exception:
                        continue
                if len(results) >= 20:  # Limit results
                    break
            if len(results) >= 20:
                break
        return ("\n" + "="*50 + "\n").join(results).encode() if results else b"No matches found"
    
    # Handle hash operations
    if src.startswith('hash:'):
        target = src[5:].strip()
        content = load_extended_source(target)
        return f"SHA256: {hashlib.sha256(content).hexdigest()}".encode()
    
    # Handle database queries
    if src.startswith(('db:', 'sql:')):
        query = src.split(':', 1)[1].strip()
        try:
            conn = sqlite3.connect(DB_PATH)
            cursor = conn.cursor()
            cursor.execute(query)
            if query.strip().lower().startswith('select'):
                results = cursor.fetchall()
                columns = [desc[0] for desc in cursor.description]
                return json.dumps([dict(zip(columns, row)) for row in results], indent=2).encode()
            else:
                conn.commit()
                return b"Query executed successfully"
        except Exception as e:
            return f"Database error: {e}".encode()
        finally:
            conn.close()
    
    # Handle Git operations
    if src.startswith('git:'):
        command = src[4:].strip()
        try:
            result = subprocess.run(['git'] + command.split(), 
                                  cwd=REPO, capture_output=True, text=True)
            return (result.stdout or result.stderr).encode()
        except Exception as e:
            return f"Git error: {e}".encode()
    
    # Handle file: prefix
    if src.startswith("file:"):
        src = src[5:]
    
    # Direct file path
    if os.path.isfile(src):
        try:
            return open(src, "rb").read()
        except Exception as e:
            return f"File read error: {e}".encode()
    
    # HTTP URL
    if src.startswith("http"):
        for attempt in range(3):
            try:
                response = SESSION.get(src, timeout=(5, 30))
                response.raise_for_status()
                return response.content
            except requests.exceptions.Timeout:
                print_warning(f"Timeout fetching {src} (attempt {attempt+1}/3)")
                time.sleep(2 ** attempt)
            except requests.exceptions.RequestException as e:
                return f"HTTP error: {e}".encode()
        return b"Failed to fetch URL after 3 attempts"
    
    # REPO-relative path with execution
    repo_path = os.path.join(REPO, src)
    if os.path.exists(repo_path):
        if os.access(repo_path, os.X_OK):
            try:
                return subprocess.run([repo_path], capture_output=True, check=True).stdout
            except Exception as e:
                return f"Execution error: {e}".encode()
        else:
            try:
                return open(repo_path, "rb").read()
            except Exception as e:
                return f"File read error: {e}".encode()
    
    # Fallback: treat as literal string
    return src.encode()

