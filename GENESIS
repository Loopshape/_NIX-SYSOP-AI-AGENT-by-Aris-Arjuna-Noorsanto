async def main():
    args = parse_arguments()
    
    # Show help if requested
    if args.help or not args.targets:
        print(__doc__)
        return
    
    # Update enabled features based on flags
    for feature in ENABLED_FEATURES:
        if hasattr(args, feature):
            # Special handling for --bounce which is an int
            if feature == 'bounce':
                ENABLED_FEATURES[feature] = args.bounce
            else:
                ENABLED_FEATURES[feature] = getattr(args, feature)
    
    # Ensure Ollama is running
    if not ensure_ollama_is_running():
        sys.exit(1)
    
    # Load and process input
    input_source = ' '.join(args.targets)
    content = load_extended_source(input_source)
    
    # Initialize database
    conn = sqlite3.connect(DB_PATH, check_same_thread=False)
    # cur = conn.cursor() # Keep cursor definition if needed for future SQL
    
    # Initialize consensus engine
    engine = EnhancedConsensusEngine(conn)
    
    # Determine if it's a special command or a prompt requiring model execution
    is_model_prompt = not any(input_source.startswith(prefix) for prefix in ['calc:', 'search:', 'hash:', 'db:', 'git:'])

    if is_model_prompt:
        print_info("Running enhanced AI consensus...")
        
        # Run consensus with Qbit-Map parameters if requested
        consensus_result = await engine.parallel_model_consensus(
            content.decode('utf-8', errors='ignore'),
            CLOUD_MODELS + LOCAL_MODELS,
            use_qbit=args.qbit,
            bounce_depth=args.bounce
        )
        
        output_text = consensus_result['output']
        
        # Handle project creation
        if args.project or any(keyword in input_source.lower() for keyword in ['project', 'create', 'build', 'scaffold']):
            project_name = args.project or f"project_{hashlib.sha256(input_source.encode()).hexdigest()[:8]}"
            stack = detect_tech_stack(input_source)
            project_tree = generate_extended_project_tree(stack, project_name)
            
            project_root = os.path.join(PROJECTS_DIR, project_name)
            created_files = []
            
            for file_path, content in project_tree.items():
                full_path = os.path.join(project_root, file_path)
                if safe_write_file(full_path, content.encode('utf-8')):
                    created_files.append(full_path)
            
            # Initialize git if requested
            if args.git and created_files:
                subprocess.run(['git', 'init'], cwd=project_root, capture_output=True)
                subprocess.run(['git', 'add', '.'], cwd=project_root, capture_output=True)
                subprocess.run(['git', 'commit', '-m', 'Initial commit'], cwd=project_root, capture_output=True)
            
            # Add project info to output
            output_text += f"\n\n--- PROJECT CREATED ---\nLocation: {project_root}\nFiles: {len(created_files)}"
        
        # Output results
        if args.json:
            result_data = {
                'input': input_source,
                'output': output_text,
                'consensus_metrics': {
                    'successful_models': consensus_result['successful_runs'],
                    'total_models': consensus_result['total_models'],
                    'score': consensus_result['consensus_score'],
                    'method': 'Qbit-Map' if args.qbit else 'Standard Entropy'
                },
                'timestamp': datetime.now().isoformat()
            }
            print(json.dumps(result_data, indent=2))
        else:
            method_name = Colors.style('Qbit-Map Fractal Consensus', Colors.MAGENTA) if args.qbit else Colors.style('Standard Entropy Consensus', Colors.GREEN)
            print(f"\n{Colors.style('=== AI CONSENSUS RESULT ===', Colors.GREEN, True)} ({method_name})")
            print(output_text)
    
    else:
        # Special command - just output the result
        print(content.decode('utf-8', errors='ignore'))
    
    conn.close()

if __name__ == "__main__":
    asyncio.run(main())