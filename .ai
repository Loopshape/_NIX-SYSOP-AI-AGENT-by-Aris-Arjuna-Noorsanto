#!/usr/bin/env bash
# === Agent Nemodian: Modernizer + AGI Runner ===

# ------------------------
# Dependencies
# ------------------------
for cmd in node python3 sqlite3 git; do
    command -v $cmd >/dev/null 2>&1 || { echo "[ERROR] $cmd required"; exit 1; }
done

# ------------------------
# Persistent Paths
# ------------------------
AI_HOME="$HOME/.sysop-ai"
ENV_HOME="$HOME/.sysop_ai_env"
AI_DATA_DB="$ENV_HOME/ai_data.db"
BLOBS_DB="$ENV_HOME/blobs.db"
PROJECTS_DIR="$ENV_HOME/projects"

mkdir -p "$AI_HOME" "$ENV_HOME" "$PROJECTS_DIR"

# ------------------------
# Temporary Workspace
# ------------------------
TMPDIR=$(mktemp -d)
trap "rm -rf $TMPDIR" EXIT

# ------------------------
# Extract Node Orchestrator
# ------------------------
cat <<'EOF' > "$TMPDIR/orchestrator.js"
import { exec } from 'child_process';
import fs from 'fs';
import path from 'path';
import sqlite3Pkg from 'sqlite3';
const sqlite3 = sqlite3Pkg.verbose();
import crypto from 'crypto';

const AI_HOME = process.env.AI_HOME;
const PROJECTS_DIR = process.env.PROJECTS_DIR;
const AI_DATA_DB_PATH = process.env.AI_DATA_DB;
const BLOBS_DB_PATH = process.env.BLOBS_DB;
const OLLAMA_BIN = process.env.OLLAMA_BIN || 'ollama';

const MODEL_POOL = ["phi3","llama3","codegemma"];
const aiDataDb = new sqlite3.Database(AI_DATA_DB_PATH);
const blobsDb = new sqlite3.Database(BLOBS_DB_PATH);

class ProofTracker { /* ... same as your ES module version ... */ }
class AIOrchestrator { /* ... same as your ES module version ... */ }

// --- Modernizer Function ---
async function modernizeDirs(dirs) {
    for (const dir of dirs) {
        if (!fs.existsSync(dir)) continue;
        const files = fs.readdirSync(dir, {withFileTypes:true});
        for (const file of files) {
            const fullPath = path.join(dir, file.name);
            if (file.isDirectory()) {
                await modernizeDirs([fullPath]);
            } else if (file.isFile() && file.name.endsWith('.js')) {
                let content = fs.readFileSync(fullPath,'utf-8');
                if (content.includes("require(")) {
                    content = content.replace(/const\s+(\w+)\s*=\s*require\(['"](.+)['"]\)/g,'import $1 from "$2"');
                    fs.writeFileSync(fullPath, content);
                    console.log(`[MODERNIZED] ${fullPath}`);
                }
            }
        }
    }
}

(async () => {
    const args = process.argv.slice(2);
    const promptArgs = args.filter(arg => !arg.startsWith('--'));
    const options = Object.fromEntries(args.filter(arg => arg.startsWith('--')).map(arg => arg.slice(2).split('=')));

    let dirsToModernize = [];
    let taskPrompt = '';

    if (promptArgs.length > 0) {
        taskPrompt = promptArgs[0];
        if (promptArgs.length > 1) {
            dirsToModernize = promptArgs.slice(1);
        }
    }

    if (dirsToModernize.length > 0) {
        await modernizeDirs(dirsToModernize);
    }

    if (taskPrompt) {
        const orchestrator = new AIOrchestrator(taskPrompt, options);
        await orchestrator.execute();
    }

    aiDataDb.close();
    blobsDb.close();
})();
EOF

# ------------------------
# Extract Python Potential Maths
# ------------------------
cat <<'EOF' > "$TMPDIR/potential.py"
import sys
task = sys.argv[1] if len(sys.argv) > 1 else "No task"
entropy = sum(ord(c) for c in task) % 100
print(f"[Python Potential] Entropy for '{task}': {entropy}")
EOF

# ------------------------
# CLI Handling
# ------------------------
CMD="$1"
shift || true

# Default to 'run' if no command given
if [[ -z "$CMD" ]] || [[ "$CMD" != "run" && "$CMD" != "memory" && "$CMD" != "blobs" && "$CMD" != "status" ]]; then
    set -- "$CMD" "$@" # push args back
    CMD="run"
fi

case "$CMD" in
    run)
        TASK_PROMPT="$1"
        shift || true
        DIRS=("$@")
        if [[ -z "$TASK_PROMPT" ]]; then
            echo "[ERROR] Usage: $0 run \"task prompt\" [dirs to modernize]"
            exit 1
        fi
        # Run Node orchestrator + modernizer
        NODE_CMD=(node "$TMPDIR/orchestrator.js" "$TASK_PROMPT" "${DIRS[@]}" --project=singlefiler --ai_home="$AI_HOME" --ai_data_db="$AI_DATA_DB" --blobs_db="$BLOBS_DB" --projects_dir="$PROJECTS_DIR")
        "${NODE_CMD[@]}"
        # Run Python maths
        python3 "$TMPDIR/potential.py" "$TASK_PROMPT"
        ;;
    memory)
        sqlite3 "$AI_DATA_DB" "SELECT rowid, task_id, prompt FROM memories ORDER BY rowid DESC;"
        ;;
    blobs)
        sqlite3 "$BLOBS_DB" "SELECT rowid, project_name, file_path FROM blobs ORDER BY rowid DESC;"
        ;;
    status)
        echo "AI_HOME: $AI_HOME"
        echo "ENV_HOME: $ENV_HOME"
        echo "Node: $(node -v)"
        echo "Python: $(python3 -V)"
        echo "SQLite: $(sqlite3 --version)"
        echo "Projects Dir: $PROJECTS_DIR"
        ;;
    *)
        echo "Usage: $0 {run|memory|blobs|status} [task prompt] [dirs...]"
        ;;
esac