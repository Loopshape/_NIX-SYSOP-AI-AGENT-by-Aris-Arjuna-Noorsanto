<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Task Orchestration Simulator</title>
    <!-- Load Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        /* Custom Keyframes for a smooth running pulse effect */
        @keyframes runningPulse {
            0%, 100% { box-shadow: 0 0 0 0 rgba(37, 99, 235, 0.7); }
            50% { box-shadow: 0 0 10px 5px rgba(37, 99, 235, 0.9); }
        }
        .task-running {
            animation: runningPulse 1.5s infinite ease-in-out;
            border-color: #2563EB !important; /* Blue 600 */
        }
    </style>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                    },
                    colors: {
                        'background-dark': '#1e293b', /* Slate 800 */
                        'card-dark': '#334155', /* Slate 700 */
                        'pending': '#94a3b8', /* Slate 400 */
                        'running': '#2563EB', /* Blue 600 */
                        'complete': '#10B981', /* Emerald 500 */
                        'failed': '#EF4444', /* Red 500 */
                    }
                }
            }
        }
    </script>
</head>
<body class="bg-background-dark min-h-screen text-white font-sans p-4">

    <!-- Main Application Container -->
    <div id="app-container" class="max-w-4xl mx-auto py-8">
        <h1 class="text-4xl font-extrabold text-center mb-2">
            Orchestrator Sandbox
        </h1>
        <p class="text-center text-pending mb-8">
            Visual simulation of a sequential task pipeline.
        </p>

        <!-- Control Panel -->
        <div class="bg-card-dark p-4 sm:p-6 rounded-xl shadow-lg mb-8 flex flex-col sm:flex-row justify-between items-center gap-4">
            <div class="text-lg font-medium text-white">
                Status: <span id="orchestration-status" class="text-pending">IDLE</span>
            </div>
            <button id="start-button" onclick="startOrchestration()"
                    class="w-full sm:w-auto px-6 py-3 bg-running text-white font-bold rounded-lg transition duration-200 hover:bg-blue-700 disabled:opacity-50 disabled:cursor-not-allowed shadow-md">
                Start Pipeline
            </button>
            <button id="reset-button" onclick="initializeTasks()" disabled
                    class="w-full sm:w-auto px-6 py-3 bg-pending text-background-dark font-bold rounded-lg transition duration-200 hover:bg-slate-500 disabled:opacity-50 disabled:cursor-not-allowed shadow-md">
                Reset
            </button>
        </div>

        <!-- Task Visualization -->
        <div id="task-container" class="space-y-4">
            <!-- Tasks will be rendered here by JavaScript -->
        </div>
    </div>

    <script>
        // Global variables
        let tasks = [];
        let isRunning = false;
        const taskData = [
            { id: 1, name: "Data Extraction (Source A)", successRate: 0.95, duration: 1500 },
            { id: 2, name: "Data Transformation (ETL)", successRate: 0.85, duration: 2000 },
            { id: 3, name: "Validate Schema & Integrity", successRate: 0.90, duration: 1000 },
            { id: 4, name: "Model Training Start", successRate: 0.98, duration: 2500 },
            { id: 5, name: "Deploy to Staging Environment", successRate: 0.70, duration: 3000 },
            { id: 6, name: "Send Notification & Report", successRate: 1.00, duration: 1200 }
        ];

        // Constants for Task States
        const STATE = {
            PENDING: 'PENDING',
            RUNNING: 'RUNNING',
            COMPLETE: 'COMPLETE',
            FAILED: 'FAILED'
        };

        // DOM elements
        const taskContainer = document.getElementById('task-container');
        const startButton = document.getElementById('start-button');
        const resetButton = document.getElementById('reset-button');
        const statusElement = document.getElementById('orchestration-status');

        /**
         * Initializes the tasks array to the PENDING state and updates the UI.
         */
        function initializeTasks() {
            console.log("Initializing tasks...");
            isRunning = false;
            tasks = taskData.map(data => ({
                ...data,
                state: STATE.PENDING
            }));
            renderTasks();
            updateControls(STATE.PENDING);
        }

        /**
         * Renders the tasks list and their status in the DOM.
         */
        function renderTasks() {
            taskContainer.innerHTML = ''; // Clear existing tasks

            tasks.forEach((task, index) => {
                // Determine color and icon based on state
                let colorClass = '';
                let icon = '';
                let iconColor = '';

                switch (task.state) {
                    case STATE.PENDING:
                        colorClass = 'border-pending';
                        icon = '⌛'; // Hourglass
                        iconColor = 'text-pending';
                        break;
                    case STATE.RUNNING:
                        colorClass = 'border-running task-running';
                        icon = '⚙️'; // Gear
                        iconColor = 'text-running';
                        break;
                    case STATE.COMPLETE:
                        colorClass = 'border-complete';
                        icon = '✅'; // Checkmark
                        iconColor = 'text-complete';
                        break;
                    case STATE.FAILED:
                        colorClass = 'border-failed';
                        icon = '❌'; // X mark
                        iconColor = 'text-failed';
                        break;
                }

                // Task HTML structure
                const taskElement = document.createElement('div');
                taskElement.className = `p-4 rounded-xl border-2 transition-all duration-500 shadow-xl ${colorClass} bg-card-dark flex items-center gap-4`;
                taskElement.innerHTML = `
                    <div class="text-3xl ${iconColor}">${icon}</div>
                    <div class="flex-grow">
                        <p class="text-lg font-bold">${task.name}</p>
                        <p class="text-sm text-gray-400">Status: ${task.state}</p>
                    </div>
                    <!-- Connector Line (visually connects tasks, only if not the last one) -->
                    ${index < tasks.length - 1 ? `
                        <div class="absolute -bottom-8 left-6 w-0.5 h-8 bg-gray-500 transform -translate-x-1/2"></div>
                    ` : ''}
                `;
                taskElement.style.position = 'relative';

                // Add progress bar for Running state
                if (task.state === STATE.RUNNING) {
                    taskElement.innerHTML += `
                        <div class="absolute bottom-0 left-0 h-1 bg-running rounded-bl-lg animate-pulse" style="width: 100%;"></div>
                    `;
                }

                taskContainer.appendChild(taskElement);
            });
        }

        /**
         * Updates the control buttons and global status display.
         * @param {string} finalState The state to set the orchestration to (e.g., STATE.COMPLETE).
         */
        function updateControls(finalState) {
            startButton.disabled = isRunning || finalState === STATE.COMPLETE || finalState === STATE.FAILED;
            resetButton.disabled = isRunning;
            
            statusElement.textContent = finalState;
            statusElement.className = '';
            
            let statusClass = '';
            if (finalState === STATE.RUNNING) statusClass = 'text-running';
            else if (finalState === STATE.COMPLETE) statusClass = 'text-complete';
            else if (finalState === STATE.FAILED) statusClass = 'text-failed';
            else statusClass = 'text-pending';

            statusElement.classList.add(statusClass);
        }

        /**
         * Core orchestration loop. Executes tasks sequentially.
         */
        async function startOrchestration() {
            if (isRunning) return;
            isRunning = true;
            updateControls(STATE.RUNNING);
            console.log("Orchestration started.");

            try {
                for (let i = 0; i < tasks.length; i++) {
                    const task = tasks[i];
                    
                    // 1. Set to RUNNING state
                    task.state = STATE.RUNNING;
                    renderTasks();
                    console.log(`Task ${task.id} (${task.name}) is RUNNING...`);

                    // 2. Wait for simulated duration
                    await new Promise(resolve => setTimeout(resolve, task.duration));

                    // 3. Determine success or failure
                    const isSuccess = Math.random() < task.successRate;

                    if (isSuccess) {
                        task.state = STATE.COMPLETE;
                        console.log(`Task ${task.id} (${task.name}) COMPLETE.`);
                    } else {
                        task.state = STATE.FAILED;
                        console.error(`Task ${task.id} (${task.name}) FAILED.`);
                        renderTasks();
                        // Stop the entire pipeline on first failure
                        updateControls(STATE.FAILED);
                        isRunning = false;
                        return; 
                    }
                    
                    // 4. Update UI after state change
                    renderTasks();
                }

                // If loop completes, the orchestration is successful
                updateControls(STATE.COMPLETE);
                console.log("Orchestration COMPLETE.");

            } catch (error) {
                console.error("An unexpected error occurred during orchestration:", error);
                updateControls(STATE.FAILED);
            } finally {
                isRunning = false;
                // Re-enable start/reset buttons based on final state
                startButton.disabled = true; 
                resetButton.disabled = false;
            }
        }

        // Initialize the app on load
        window.onload = initializeTasks;
    </script>
</body>
</html>


