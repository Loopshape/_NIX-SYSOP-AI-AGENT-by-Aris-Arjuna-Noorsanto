# Function to interact with Ollama (via CLI for simplicity)
def call_ollama(prompt, model="2244:latest"):
    try:
        cmd = f"ollama run {model} \"{prompt}\""
        result = subprocess.run(cmd, shell=True, capture_output=True, text=True, check=True)
        return result.stdout.strip()
    except subprocess.CalledProcessError as e:
        print(f"Error calling Ollama: {e.stderr}", file=sys.stderr)
        return None

def rebase_xml_element(xml_content, xpath_to_rebase, rebase_instruction):
    try:
        root = ET.fromstring(xml_content)
        element = root.find(xpath_to_rebase)
        if element is not None:
            original_element_str = ET.tostring(element, encoding='unicode')
            ollama_prompt = f"Rebase this XML snippet: '{original_element_str}' according to: '{rebase_instruction}'. Return ONLY the new XML snippet."
            rebased_element_str = call_ollama(ollama_prompt)
            if rebased_element_str:
                # This part is complex: replacing an element while maintaining offset/structure
                # For simplicity, we'll just replace the text content or a simple element
                # A more advanced AI would generate code for precise XML manipulation
                new_element = ET.fromstring(rebased_element_str)
                element.tag = new_element.tag # Example: rebase tag
                element.text = new_element.text # Example: rebase text
                # More complex rebase would involve children, attributes etc.
                return ET.tostring(root, encoding='unicode')
        return xml_content
    except Exception as e:
        print(f"Error rebasing XML: {e}", file=sys.stderr)
        return xml_content

