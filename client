#!/usr/bin/env node
/**
 * ollama_converge_build.js
 *
 * Orchestrator that forces Ollama to build a fullscreen WebGL 3D Hamburg scene
 * using a strict mandatory model pool: ['loop','2244','core','code','coin'].
 *
 * It runs a proof-of-convergence loop:
 *  - runs models in parallel each iteration,
 *  - normalizes and scores outputs,
 *  - checks for convergence / validation,
 *  - iterates with "improve this" prompt if not converged.
 *
 * Output: hamburg_3d_final.html
 *
 * Usage:
 *   node ollama_converge_build.js
 *
 * Notes:
 *  - Ollama must be installed and accessible via `ollama` command.
 *  - This script relies on heuristics to validate HTML/Three.js presence.
 */

import { exec as _exec } from "child_process";
import { promisify } from "util";
import fs from "fs";
import os from "os";
const exec = promisify(_exec);

const MODELS = ["loop", "2244", "core", "code", "coin"]; // strict mandatory order/pool
const MAX_ITER = 5;
const CONVERGENCE_SIM_THRESHOLD = 0.88; // average similarity threshold to declare convergence
const MIN_VALID_SCORE = 0.6; // heuristic to accept candidate as valid
const OUTPUT_FILE = "hamburg_3d_final.html";

function log(...args) {
  console.log(new Date().toISOString(), ...args);
}

// Normalize output for comparison
function normalizeText(s) {
  if (!s) return "";
  return s
    .replace(/\r/g, "")
    .replace(/\t+/g, " ")
    .replace(/[ ]{2,}/g, " ")
    .trim();
}

// Simple token Jaccard similarity (fast, deterministic)
function jaccardSim(a, b) {
  const sa = new Set(a.split(/\W+/).filter(Boolean));
  const sb = new Set(b.split(/\W+/).filter(Boolean));
  if (sa.size === 0 && sb.size === 0) return 1;
  const inter = [...sa].filter((x) => sb.has(x)).length;
  const uni = new Set([...sa, ...sb]).size;
  return uni === 0 ? 0 : inter / uni;
}

// Compute average pairwise similarity among outputs
function avgPairwiseSim(arr) {
  const n = arr.length;
  if (n <= 1) return 1;
  let sum = 0;
  let count = 0;
  for (let i = 0; i < n; i++) {
    for (let j = i + 1; j < n; j++) {
      sum += jaccardSim(normalizeText(arr[i]), normalizeText(arr[j]));
      count++;
    }
  }
  return count === 0 ? 0 : sum / count;
}

// Heuristic scoring for an output: rewards DOCTYPE, three.js import, canvas/responsive resize, Hamburg coords
function heuristicScore(out) {
  const s = normalizeText(out).toLowerCase();
  let score = 0;

  // DOCTYPE / HTML root
  if (s.includes("<!doctype html") || s.includes("<html")) score += 0.25;

  // Three.js imports or usage
  if (s.includes("three.module") || s.includes("three.js") || /three\b/.test(s)) score += 0.25;

  // Fullscreen canvas or renderer setSize window.innerWidth/innerHeight
  if (s.includes("window.innerwidth") || s.includes("setsize(") || s.includes("canvas") || s.includes("renderer.setsize")) score += 0.15;

  // OrbitControls / controls
  if (s.includes("orbitcontrols") || s.includes("controls.enabled")) score += 0.05;

  // Hamburg coordinates (latitude/longitude)
  // Accept common variants and exact Hamburg coordinates
  const hamburgCandidates = ["53.5511", "9.9937", "hamburg", "hamburg, germany"];
  if (hamburgCandidates.some((c) => s.includes(c))) score += 0.2;

  // Marker/marker geometry or sphere for location
  if (s.includes("marker") || s.includes("spheregeometry") || s.includes("mesh")) score += 0.05;

  // Ensure comments & clear instructions (small bonus)
  if (s.includes("<!--") || s.includes("//") || s.includes("/*")) score += 0.05;

  // cap to 1
  return Math.min(1, score);
}

// Extract most plausible HTML or code block from model output
function extractBestBlock(out) {
  if (!out) return "";
  // If the model returned fenced code blocks (```html ... ```), prefer them
  const codeFenceRegex = /```(?:html|htm|x?html)?\s*([\s\S]*?)```/gi;
  let m;
  const blocks = [];
  while ((m = codeFenceRegex.exec(out)) !== null) {
    if (m[1]) blocks.push(m[1].trim());
  }
  if (blocks.length > 0) {
    // choose longest block
    blocks.sort((a, b) => b.length - a.length);
    return blocks[0];
  }

  // If no fences, try to find full HTML (from <!DOCTYPE to </html>)
  const htmlRegex = /<!doctype html[\s\S]*<\/html>/i;
  const htmlMatch = out.match(htmlRegex);
  if (htmlMatch) return htmlMatch[0];

  // fallback: if output is mostly HTML-ish (has <html> tag), return substring around <html>... </html>
  const open = out.indexOf("<html");
  const close = out.lastIndexOf("</html>");
  if (open >= 0 && close > open) return out.substring(open, close + 7);

  // as last resort: return the entire output
  return out.trim();
}

// Fuse outputs: strategy
// 1) extract "best block" from each model output
// 2) score each block by heuristicScore
// 3) if one block passes MIN_VALID_SCORE and majority similarity exists, choose best-scoring block
// 4) otherwise, produce a fused concatenation but prefer unique lines and preserve largest block
function fuseOutputs(outputs) {
  const blocks = outputs.map((o) => extractBestBlock(o) || "");
  const scored = blocks.map((b) => ({ block: b, score: heuristicScore(b) }));
  // sort by score desc then length desc
  scored.sort((a, b) => b.score - a.score || b.block.length - a.block.length);

  // quick pick: top candidate
  const top = scored[0];

  // Average similarity among blocks
  const avgSim = avgPairwiseSim(blocks.filter(Boolean));

  log("Fusion heuristic: top score =", top.score.toFixed(3), "avgSim =", avgSim.toFixed(3));

  // If top is reasonably valid and similarity is high, pick it as final
  if (top.score >= MIN_VALID_SCORE && avgSim >= CONVERGENCE_SIM_THRESHOLD) {
    return { fused: top.block, reason: "top-scoring candidate with high avg similarity" };
  }

  // If top score is strong enough and other blocks are similar to top, accept top
  let similarCount = 0;
  for (const b of blocks) {
    if (!b) continue;
    const sim = jaccardSim(normalizeText(b), normalizeText(top.block));
    if (sim >= 0.75) similarCount++;
  }
  if (top.score >= MIN_VALID_SCORE && similarCount >= Math.ceil(blocks.length / 2)) {
    return { fused: top.block, reason: "top candidate supported by majority" };
  }

  // Otherwise produce "merged" block by taking top and augmenting with unique useful lines from others
  const linesSet = new Set(
    top.block
      .split(/\r?\n/)
      .map((l) => l.trim())
      .filter(Boolean)
  );

  for (const b of blocks) {
    if (!b) continue;
    const lines = b.split(/\r?\n/).map((l) => l.trim()).filter(Boolean);
    for (const l of lines) {
      // avoid duplicating import lines that differ only by CDN vs module path
      if (!linesSet.has(l)) {
        // only add lines that look like valid HTML/JS or helpful text
        if (l.length > 5 && l.length < 400) linesSet.add(l);
      }
    }
  }

  // Reconstruct: preserve top block's structure first
  const mergedLines = top.block.split(/\r?\n/).map((l) => l);
  // Append any extra useful lines not present in top (naive)
  for (const l of Array.from(linesSet)) {
    if (!top.block.includes(l)) mergedLines.push(l);
  }

  return { fused: mergedLines.join("\n"), reason: "merged top candidate with unique content from others" };
}

// Run models in parallel with the given promptText, return outputs as array in strict order of MODELS
async function runAllModelsParallel(promptText) {
  const tasks = MODELS.map(async (model) => {
    try {
      // Use --no-stream if available or similar options depending on your Ollama setup; keep simple here
      // Quote and escape the prompt
      const safePrompt = promptText.replace(/(["`\\$])/g, "\\$1");
      const cmd = `ollama run ${model} "${safePrompt}"`;
      log(`starting model ${model}`);
      const { stdout, stderr } = await exec(cmd, { maxBuffer: 1024 * 1024 * 10 });
      if (stderr && stderr.trim()) {
        log(`[${model}] stderr:`, stderr.slice(0, 200).replace(/\n/g, " "));
      }
      const out = stdout ? stdout.toString() : "";
      log(`completed model ${model} (output ${out.length} bytes)`);
      return { model, out };
    } catch (err) {
      log(`model ${model} failed:`, err.message || err);
      return { model, out: "" };
    }
  });

  const results = await Promise.all(tasks);
  // Ensure return in strict MODELS order
  const ordered = MODELS.map((m) => results.find((r) => r.model === m) || { model: m, out: "" });
  return ordered.map((r) => r.out);
}

// Base prompt for initial build and for subsequent improvement iterations
function basePrompt(previous = "") {
  const requirements = `
You are required to BUILD A COMPLETE, RUNNABLE fullscreen WebGL (Three.js recommended) HTML file that centers on Hamburg, Germany (GPS lat 53.5511, lon 9.9937). 
CRITICAL:
- Produce a single HTML file (doctype + html + head + body) with embedded JS (or module imports) that runs in a modern browser.
- MUST include fullscreen canvas, responsive resizing (window resize), camera, lighting, OrbitControls or equivalent, and a marker at Hamburg coords.
- Include at least three labeled GPS-markers for Hamburg POIs (e.g., Rathaus, HafenCity, Alster) with lat/lon.
- No placeholders like "TODO" or "insert texture". Provide working CDN imports or module usage. Use public CDN for Three.js if necessary.
- Add comments for clarity. Minimize external dependencies beyond Three.js and any CDN-hosted small libs.
- Output must be purely the HTML file (or fenced code block with html) and runnable when saved to disk. Do not ask the user questions.
- Make it compact but production-ready; small assets via CDN ok.
`;

  const instruction = previous
    ? `IMPROVE the previous candidate HTML below. Fix issues, ensure it runs, and ensure GPS markers are present. Previous candidate:\n\n${previous}\n\nMake the output a final single HTML file.`
    : `Build the initial full HTML.`;

  return requirements + "\n" + instruction;
}

async function convergeBuild() {
  log("Starting convergence build with models:", MODELS.join(", "));
  let previousFused = "";
  for (let iter = 1; iter <= MAX_ITER; iter++) {
    log(`\n=== ITERATION ${iter}/${MAX_ITER} ===`);
    const promptText = basePrompt(previousFused);
    const outputs = await runAllModelsParallel(promptText);

    // Normalize outputs & compute similarity
    const normalized = outputs.map((o) => normalizeText(o));
    const avgSim = avgPairwiseSim(normalized);
    log(`Average pairwise similarity among models: ${avgSim.toFixed(3)}`);

    // Fuse outputs
    const { fused, reason } = fuseOutputs(outputs);
    log("Fusion reason:", reason);

    // Score fused candidate
    const fusedScore = heuristicScore(fused);
    log("Fused candidate heuristic score:", fusedScore.toFixed(3));

    // Quick validation: ensure mandatory features exist
    const checks = {
      hasDoctype: /<!doctype html/i.test(fused),
      hasHtmlTag: /<html/i.test(fused),
      hasThree: /three(\.module|\.js)?/i.test(fused) || /from ['"].*three.*['"]/i.test(fused),
      hasResize: /window\.innerWidth|window\.innerHeight|renderer\.setSize/i.test(fused),
      hasHamburg: /53\.5511|9\.9937|hamburg/i.test(fused)
    };
    log("Validation checks:", checks);

    // Decide if converged/acceptable
    const converged =
      avgSim >= CONVERGENCE_SIM_THRESHOLD && (fusedScore >= MIN_VALID_SCORE || (checks.hasDoctype && checks.hasThree && checks.hasHamburg));

    if (converged) {
      log("Convergence criteria met. Writing final file:", OUTPUT_FILE);
      fs.writeFileSync(OUTPUT_FILE, fused, "utf8");
      log("Final file saved. Exiting.");
      return { success: true, file: OUTPUT_FILE, iter, fusedScore, reason };
    }

    // If not converged but fused candidate passes minimal validation, consider accepting early if iter==MAX_ITER
    if (iter === MAX_ITER) {
      const accept = fusedScore >= 0.45 || (checks.hasDoctype && checks.hasThree && checks.hasHamburg);
      if (accept) {
        log("Max iterations reached but fused candidate looks acceptable. Saving anyway.");
        fs.writeFileSync(OUTPUT_FILE, fused, "utf8");
        return { success: true, file: OUTPUT_FILE, iter, fusedScore, reason: "max-iter-accepted" };
      } else {
        log("Max iterations reached and candidate failed minimal acceptance. Saving best candidate for inspection.");
        fs.writeFileSync("hamburg_3d_best_failed.html", fused, "utf8");
        return { success: false, file: "hamburg_3d_best_failed.html", iter, fusedScore, reason: "failed-validation" };
      }
    }

    // Prepare for next iteration: use fused output as 'previous' for improvements
    previousFused = fused;
    log("No convergence yet. Feeding fused candidate back to models for improvement...");
  }
}

// Entrypoint
(async () => {
  try {
    const res = await convergeBuild();
    if (res.success) {
      log("BUILD SUCCESS:", res);
      console.log("\n✅ Final HTML written to:", res.file);
      console.log("Open it in a browser (double-click or serve via static server).");
    } else {
      log("BUILD FAILED / PARTIAL:", res);
      console.log("\n⚠️ Build did not fully converge. Inspect:", res.file);
    }
  } catch (err) {
    console.error("Fatal error in orchestrator:", err);
    process.exit(1);
  }
})();
