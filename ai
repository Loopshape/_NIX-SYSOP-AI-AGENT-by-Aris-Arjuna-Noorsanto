manage_ssh() {
    case "$1" in
        ls) ls -la "$SSH_DIR" ;;
        gen)
            read -p "Enter key name (e.g., id_rsa_project): " key_name
            ssh-keygen -t rsa -b 4096 -f "$SSH_DIR/$key_name"
            log_event "SSH" "Generated new key: $key_name"
            ;;
        *) echo "Usage: ai ssh-key [ls|gen]" ;;
    esac
}


