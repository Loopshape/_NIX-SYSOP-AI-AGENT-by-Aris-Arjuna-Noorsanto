# Helper function to run the orchestrator with session check
run_ai_task() {
    local full_prompt="$*"

    # 1. Hyphen Check: If prompt contains a hyphen, route directly to Ollama (quick escape route)
    if [[ "$full_prompt" == *\-* ]]; then
        echo "[INFO] Prompt contains a hyphen ('$full_prompt'). Bypassing orchestrator and sending directly to Ollama."
        if command -v "$OLLAMA_BIN" &> /dev/null; then
            # Run Ollama directly using llama3 as a default fast model
            "$OLLAMA_BIN" run llama3 "$full_prompt"
        else
            echo "[ERROR] Ollama command not found. Cannot execute hyphenated prompt directly."
        fi
        return
    fi

    # 2. Non-Hyphenated Prompt: Route to Orchestrator (.mjs)
    local prompt="$full_prompt"

    # Append project flag if session is active
    if [ -f "$SESSION_FILE" ]; then
        local proj_name=$(cat "$SESSION_FILE")
        prompt="$prompt --project=$proj_name"
    fi

    log_event "TASK_START" "Prompt: $prompt"
    if [ ! -f "$ORCHESTRATOR_FILE" ]; then
        log_event "ERROR" "Orchestrator file not found. Run 'ai status' or 'ai setup'."
        return
    fi

    # Execute the Node.js orchestrator, passing the prompt and any flags
    node "$ORCHESTRATOR_FILE" $prompt
    log_event "TASK_END" "Task finished."
}


