#!/usr/bin/env node

import readline from 'readline';
import path from 'path';

// --- CONFIGURABLE CONSTANTS ---
const DIALOG_HISTORY_HEIGHT = 5; // Lines reserved for the persistent dialog history buffer (including header)
const MOCK_FILE_CONTENTS = {
    'src/config_setup.py': 'def initialize_engine(): # Setup structures for consensus loop.',
    'src/data_loader.ts': 'const data = loadExternalData("api/v2"); // Validate and transform.',
    'docs/reporting_logic.md': '# Generate final report. Key: cross-reference findings.',
};
const DEDICATED_MODELS = ['loop', '2244', 'code', 'core', 'coin'];

// --- UTILITIES ---

const KEYWORDS = ['const', 'let', 'var', 'def', 'return', 'if', 'else', 'for', 'while', 'class', 'function', 'import', 'export', 'async', 'await', 'new', 'this', 'set', 'get'];

function assignModel(filePath) {
    if (filePath.endsWith('.py') || filePath.endsWith('.ts')) return 'code';
    if (filePath.endsWith('.md')) return 'coin';
    if (filePath.includes('config') || filePath.includes('setup')) return 'core';
    if (filePath.includes('data')) return '2244';
    return 'loop';
}

function getLabelColor(label) {
    const hash = label.split('').reduce((acc, c) => acc + c.charCodeAt(0), 0);
    return `\x1b[1;${31 + (hash % 6)}m`; // red, green, yellow, blue, magenta, cyan
}

/** Colors tokens based on simulated semantic type for better readability. */
function colorToken(token) {
    // 1. Strings (handles tokens that start and/or end with quotes, even if incomplete or split)
    if (token.startsWith('"') || token.startsWith("'") || token.endsWith('"') || token.endsWith("'")) 
        return `\x1b[32m${token}\x1b[0m`; // Green

    // 2. Keywords
    if (KEYWORDS.includes(token.toLowerCase())) 
        return `\x1b[35m${token}\x1b[0m`; // Magenta

    // 3. Numbers
    if (/^\d+(\.\d+)?$/.test(token)) 
        return `\x1b[33m${token}\x1b[0m`; // Yellow

    // 4. Punctuation (strict match)
    if (/^[\(\)\{\}\[\]\.,;:\<\>\=\+\-\*\/%]$/.test(token)) 
        return `\x1b[1;37m${token}\x1b[0m`; // Bold White

    // 5. Variables/Identifiers (alphanumeric or underscore)
    if (/^\w+$/.test(token)) 
        return `\x1b[36m${token}\x1b[0m`; // Cyan

    // 6. Generic/Whitespace/Fallback (e.g., spaces, unclassified words)
    return token; 
}


// --- TERMINAL MANAGER (Priority Output Handler with History Buffer) ---

/**
 * Manages all cursor positioning and output drawing to guarantee the REPL prompt
 * and the fixed-height history buffer remain stable during concurrent streaming.
 */
class TerminalManager {
    constructor(dashboardLines) {
        this.dashboardLines = dashboardLines;
        this.historyHeight = DIALOG_HISTORY_HEIGHT;
        this.dialogHistory = [];
        this.currentDialogResponse = ''; // Used to capture the full dialog stream before adding to history

        this.rl = readline.createInterface({
            input: process.stdin,
            output: process.stdout,
            prompt: '\x1b[1;33mYou >\x1b[0m '
        });
    }

    clearLine() {
        readline.cursorTo(process.stdout, 0);
        readline.clearLine(process.stdout, 0);
    }
    
    redrawPrompt() {
        this.rl.prompt(true);
    }

    /** Clears and redraws the fixed-height dialog history buffer. */
    _drawDialogHistory() {
        // 1. Move cursor to the starting line of the history buffer (above prompt)
        readline.moveCursor(process.stdout, 0, -(this.historyHeight + 1)); 

        // 2. Clear and redraw the reserved area (History Header + historyHeight - 1 lines)
        for (let i = 0; i < this.historyHeight; i++) {
            this.clearLine();
            if (i < this.historyHeight - 1) process.stdout.write('\n');
        }

        // 3. Move cursor back up to the start of history area
        readline.moveCursor(process.stdout, 0, -this.historyHeight);

        // 4. Print history entries
        const displayHistory = this.dialogHistory.slice(-(this.historyHeight - 1));
        
        // History Header
        this.clearLine();
        process.stdout.write('\x1b[40m\x1b[1;37m--- DIALOG HISTORY ---\x1b[0m\n');
        
        // History entries
        displayHistory.forEach(entry => {
            this.clearLine();
            process.stdout.write(entry.substring(0, process.stdout.columns - 3) + '\n');
        });

        // 5. Fill remaining space (if history is short)
        for (let i = displayHistory.length; i < this.historyHeight - 1; i++) {
            this.clearLine();
            process.stdout.write('\n');
        }

        // 6. Move cursor back down to the prompt line
        readline.cursorTo(process.stdout, 0);
        this.redrawPrompt();
    }

    /** Adds a complete, formatted entry to history and triggers a redraw. */
    addHistoryEntry(entry) {
        // Remove existing color codes before pushing to history to keep the display clean
        const cleanEntry = entry.replace(/\x1b\[[0-9;]*m/g, ''); 
        this.dialogHistory.push(cleanEntry);
        if (this.dialogHistory.length > 50) this.dialogHistory.shift(); 
        this._drawDialogHistory();
    }

    /** Moves the cursor to the dashboard region. */
    moveToDashboard() {
        readline.cursorTo(process.stdout, 0);
        // Move up past the History Buffer and the Dashboard lines
        readline.moveCursor(process.stdout, 0, -(this.historyHeight + 1 + this.dashboardLines)); 
    }

    /** Moves the cursor back down past the dashboard region to the stream area. */
    movePastDashboard() {
        readline.moveCursor(process.stdout, 0, this.dashboardLines);
        readline.cursorTo(process.stdout, 0);
    }

    /**
     * Writes streaming output safely (used for Batch and real-time Dialog tokens).
     * This handles the constant cursor adjustment needed for concurrent scrolling output.
     * @param {string} data - The content to write.
     * @param {boolean} isNewline - Whether this write concludes the line.
     */
    writeStream(data, isNewline = false) {
        // Clear the prompt line
        this.clearLine();
        
        // Move up past the history buffer and print the new stream data
        readline.moveCursor(process.stdout, 0, -(this.historyHeight + 1));
        process.stdout.write(data);
        if (isNewline) process.stdout.write('\n');

        // Move back down to the prompt line
        this._drawDialogHistory(); 
    }
}

// --- MOCK STREAMING BACKEND ---

/**
 * Simulates a token-by-token streaming response from a model using the TM.
 * @returns {string} The full response (UNCOLORED) for history logging.
 */
async function streamBackendResponse(model, prompt, prefix = '', tm) {
    // Enhanced mock response string to demonstrate token coloring
    const response = `(MOCK:${model}) Analyzing: ${prompt.substring(0, 20)}... The code model suggests const variable 'X_MAX' = 10; return X_MAX; The string is "Processed".`;
    
    // Split on whitespace OR punctuation OR quote marks to isolate tokens for coloring
    const tokens = response.split(/(\s+|["']|[\(\)\{\}\[\]\.,;:\<\>\=\+\-\*\/%])/).filter(t => t.length > 0);
    let fullResponse = '';

    tm.writeStream(prefix);

    for (const token of tokens) {
        // Apply coloring to the token for display
        const coloredToken = colorToken(token); 
        tm.writeStream(coloredToken, false);
        fullResponse += token;
        await new Promise(r => setTimeout(r, 10 + Math.random() * 5));
    }
    
    tm.writeStream('', true); 
    return fullResponse;
}

// --- META-CONSENSUS BATCH ENGINE ---

class MetaConsensusEngine {
    constructor(files, maxIter, tm) {
        this.files = files;
        this.maxIterations = maxIter;
        this.tm = tm;
        this.states = {};
        this.fusedOutput = '';
        this.lastSignature = '';
        this.currentIter = 0;
        this.isComplete = false;
        this.dashboardLines = files.length + 3;
        files.forEach(f => this.initState(f));
    }

    initState(f) {
        this.states[f] = { progress: 0, entropy: Math.random() * 100, influence: 0.6 + Math.random() * 0.4, output: '', model: assignModel(f) };
    }

    updateState(f) {
        const s = this.states[f];
        s.progress = Math.min(1, s.progress + 0.05 + Math.random() * 0.05);
        s.entropy = Math.max(0, s.entropy - (s.influence * 15 * Math.random() * 0.1));
        s.influence = Math.min(1, s.influence + (Math.random() - 0.4) * 0.005);
    }

    /** * NEW: Provides a structured, human-readable summary of a single file's state.
     */
    queryState(filePath) {
        if (this.files.includes(filePath)) {
            const s = this.states[filePath];
            const fileBase = path.basename(filePath);
            
            const summary = [
                `Current State for \x1b[1;36m${fileBase}\x1b[0m (Iteration ${this.currentIter}):`,
                `  \x1b[32mModel:\x1b[0m ${s.model.toUpperCase()}`,
                `  \x1b[32mProgress:\x1b[0m ${(s.progress * 100).toFixed(1)}%`,
                `  \x1b[32mEntropy:\x1b[0m ${s.entropy.toFixed(2)} (High value suggests disagreement)`,
                `  \x1b[32mInfluence:\x1b[0m ${(s.influence * 100).toFixed(1)}% (Weight in final fusion)`,
                `  \x1b[32mLast Output Snippet:\x1b[0m ${s.output.substring(0, 50).replace(/\n/g, ' ')}...`
            ];
            return summary.join('\n');
        } else {
            return `\x1b[31m[ERROR]\x1b[0m File \x1b[36m${filePath}\x1b[0m not found in batch list. Current files are: [${this.files.map(f => path.basename(f)).join(', ')}]`;
        }
    }

    /** Draws the dashboard safely at the top of the terminal. */
    _drawDashboard(converged = false) {
        this.tm.moveToDashboard();
        
        const status = this.isComplete ? 'COMPLETE' : (converged ? 'CONVERGED' : 'RUNNING'),
              color = this.isComplete ? '\x1b[47m\x1b[30m' : (converged ? '\x1b[42m' : '\x1b[44m');

        let out = `${color}| META-CONSENSUS DASHBOARD | ITER:${this.currentIter}/${this.maxIterations} STATUS:${status} | Sig:${this.lastSignature.substring(0, 10)}...\x1b[0m\n`;
        out += '|--------------------------------------------------------------------------------\n';

        for (const f of this.files) {
            const s = this.states[f];
            const c = getLabelColor(f), base = path.basename(f).padEnd(20), mod = s.model.toUpperCase().padEnd(6);
            const p = (s.progress * 100).toFixed(0).padStart(3);
            const ebar = '█'.repeat(Math.floor(s.entropy / 10)).padEnd(10);
            const ibar = '▒'.repeat(Math.floor(s.influence * 10)).padEnd(10);

            out += `| ${c}${base}\x1b[0m (${mod}) | PROG:${p}% | ENT:[\x1b[33m${ebar}\x1b[0m] | INF:[\x1b[35m${ibar}\x1b[0m]\n`;
        }
        out += '|--------------------------------------------------------------------------------';

        // Write line by line directly to the reserved top area
        const lines = out.split('\n');
        for (let i = 0; i < this.dashboardLines; i++) {
            readline.cursorTo(process.stdout, 0);
            readline.clearLine(process.stdout, 0);
            if (i < lines.length) process.stdout.write(lines[i]);
            if (i < this.dashboardLines - 1) process.stdout.write('\n');
        }

        // Return cursor control to the main stream area
        this.tm.movePastDashboard();
    }

    fuseOutputs() {
        const out = this.files.map(f => Array(Math.max(1, Math.floor(this.states[f].influence * 3))).fill(this.states[f].output).join('\n'));
        this.fusedOutput = out.join('\n--- FUSED ---\n').trim();
    }

    getSignature(o) { return o.substring(0, 100); }

    async processFile(f, prevFusion) {
        const s = this.states[f], model = s.model, prompt = `[${model}] Analyze ${f} entropy:${s.entropy.toFixed(1)} prevFusion:${prevFusion.substring(0, 30)}...`;
        
        const prefix = `${getLabelColor(f)}[R${this.currentIter}|${path.basename(f)}]\x1b[0m > `;

        this.tm.writeStream(`\n\x1b[90m--- Batch Processing ${path.basename(f)} ---\x1b[0m\n`, true);

        for (let i = 0; i < 3; i++) {
            this.updateState(f);
            await new Promise(r => setTimeout(r, 10)); 

            // Stream batch tokens using the TM
            await streamBackendResponse(model, prompt, prefix, this.tm);
            s.output += `(Batch-Token-${i}) `;
        }
        this.tm.writeStream(`\x1b[90m--- End ${path.basename(f)} ---\x1b[0m\n`, true);
    }

    /** Main loop, runs as a continuous non-blocking process. */
    async run() {
        // Continuous dashboard update loop 
        const dashboardLoop = setInterval(() => {
            this._drawDashboard(this.lastSignature.length > 0 && !this.isComplete);
        }, 100); 

        for (let iter = 1; iter <= this.maxIterations; iter++) {
            this.currentIter = iter;
            this.tm.writeStream(`\n\x1b[1;37m--- META ITERATION ${iter} STARTED ---\x1b[0m\n`, true);
            
            const prevFusion = this.fusedOutput;

            // Process all files concurrently
            await Promise.all(this.files.map(f => this.processFile(f, prevFusion)));

            this.fuseOutputs();
            const sig = this.getSignature(this.fusedOutput);

            if (this.lastSignature && sig === this.lastSignature) {
                this.isComplete = true;
                this.tm.writeStream(`\n\x1b[32m[CONVERGED]\x1b[0m Iteration ${iter}\n`, true);
                break;
            }
            this.lastSignature = sig;

            this.tm.writeStream(`\n\x1b[1;32m[FUSED OUTPUT Sig:${sig.substring(0, 10)}...]\x1b[0m\n`, true);
            this.tm.writeStream(this.fusedOutput.substring(0, 300) + '...\n', true);
        }

        // Cleanup
        clearInterval(dashboardLoop);
        this.isComplete = true;
        this._drawDashboard(true);
        this.tm.writeStream(`\n\x1b[1;36m[Consensus Complete]\x1b[0m Max iterations reached.\n`, true);
    }
}

// --- HYBRID MODE ORCHESTRATOR ---

async function startHybridMode(files, models, iterations) {
    const filePaths = Object.keys(MOCK_FILE_CONTENTS);
    const dashboardLines = filePaths.length + 3;
    const tm = new TerminalManager(dashboardLines);

    // Reserve space for all fixed elements (Dashboard + History + Prompt)
    for (let i = 0; i < dashboardLines + tm.historyHeight + 1; i++) {
        process.stdout.write('\n');
    }
    tm._drawDialogHistory(); // Draw initial empty history buffer
    tm.redrawPrompt();

    const engine = new MetaConsensusEngine(filePaths, iterations, tm);

    // 1. Start batch process in background
    const batchPromise = engine.run();

    // 2. Setup REPL interaction
    tm.rl.on('line', async (line) => {
        const prompt = line.trim();
        const parts = prompt.split(' ');
        const command = parts[0].toUpperCase();
        
        if (prompt.toLowerCase() === 'exit') {
            tm.rl.close();
            return;
        }
        if (!prompt) {
            tm.redrawPrompt();
            return;
        }

        // --- NEW: Handle Internal QUERY Command ---
        if (command === 'QUERY') {
            const filePath = parts[1];
            if (!filePath) {
                 const error = `\x1b[31m[ERROR]\x1b[0m Usage: QUERY <filename>. Available files: [${Object.keys(MOCK_FILE_CONTENTS).join(', ')}]`;
                 tm.addHistoryEntry(error);
            } else {
                tm.addHistoryEntry(`\x1b[1;33mYou:\x1b[0m QUERY ${filePath}`);
                const result = engine.queryState(filePath);
                tm.writeStream('\n\x1b[1;37m--- ENGINE STATE QUERY ---\x1b[0m\n', true);
                tm.writeStream(result + '\n', true);
                tm.addHistoryEntry(result);
            }
            tm.redrawPrompt();
            return;
        }
        // --- END QUERY Command ---

        
        // Log the user's query to history
        tm.addHistoryEntry(`\x1b[1;33mYou:\x1b[0m ${prompt}`);

        if (engine.isComplete) {
            tm.writeStream('\n\x1b[33m[WARN]\x1b[0m Batch process is complete. Dialog fusion ended.\n', true);
            return;
        }

        tm.writeStream(`\n\x1b[1;37m--- INTERACTIVE QUERY ---\x1b[0m\n`, true);
        
        const responses = {};

        // Stream models concurrently
        await Promise.all(models.map(async model => {
            const prefix = `${getLabelColor(model)}[DIALOG|${model}]\x1b[0m > `;
            const fullResponse = await streamBackendResponse(model, prompt, prefix, tm);
            responses[model] = fullResponse;
        }));

        tm.writeStream(`\x1b[1;37m--- END QUERY ---\x1b[0m\n`, true);

        // Add all completed model responses to the fixed history buffer
        Object.entries(responses).forEach(([model, response]) => {
            const formattedEntry = `${getLabelColor(model)}[${model}]:\x1b[0m ${response}`;
            tm.addHistoryEntry(formattedEntry);
        });

        tm.redrawPrompt();
    });

    tm.rl.on('close', () => {
        tm.clearLine();
        console.log('\n\x1b[1;36m[CLI Session]\x1b[0m Ended.');
        process.exit(0);
    });

    // Wait for the batch process to finish
    await batchPromise;
}

// --- CLI ENTRY POINT ---

function printUsage() {
    console.log(`\n\x1b[1;37mUsage:\x1b[0m`);
    console.log(`  \x1b[1;36mnode cli.js hybrid [flags]\x1b[0m  - Runs batch consensus and interactive dialog concurrently.`);
    console.log(`\n\x1b[1;37mCommands (in Dialog):\x1b[0m`);
    console.log(`  \x1b[35mQUERY <filename>\x1b[0m - Get real-time status (Progress, Entropy, Influence) of a batch file.`);
    console.log(`  \x1b[35mexit\x1b[0m             - End the session.`);
    console.log(`\n\x1b[1;37mFlags (for hybrid mode):\x1b[0m`);
    console.log(`  \x1b[35m--models=<name1,name2>\x1b[0m Comma-separated list of models for dialog (default: core,loop).`);
    console.log(`  \x1b[35m--iterations=<N>\x1b[0m     Max convergence iterations for batch (default: 6).`);
    console.log(`\nExample:`);
    console.log(`  node cli.js hybrid --models=core,code --iterations=4`);
}

async function main() {
    const args = process.argv.slice(2);
    const cmd = args[0];

    const flags = {};
    args.slice(1).forEach(a => {
        if (a.startsWith('--')) {
            const [k, v] = a.slice(2).split('=');
            flags[k] = v === undefined ? true : v;
        }
    });

    if (cmd === 'hybrid') {
        const models = flags.models ? flags.models.split(',') : ['core', 'loop'];
        const iterations = flags.iterations ? parseInt(flags.iterations) : 6;

        if (isNaN(iterations) || iterations <= 0) {
            console.error(`\x1b[31m[ERROR]\x1b[0m --iterations must be a positive integer.`);
            return;
        }

        await startHybridMode(Object.keys(MOCK_FILE_CONTENTS), models, iterations);
    } else {
        console.error(`\x1b[31m[ERROR]\x1b[0m Unknown command or mode specified: '${cmd}'`);
        printUsage();
    }
}

main();