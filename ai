        regex: /^think\s+(.*)/i,
        handler: ({ match }) => {
            const thoughtPrompt = match[1].trim();
            const enhancedPrompt = `Act as a senior analyst. Provide a detailed, analytical, and expansive response to the following query, including your reasoning: "${thoughtPrompt}"`;
            console.log(`[AI-MODE] Executing request in 'think' mode (detailed, analytical).`);
            return ollamaQuery(enhancedPrompt); 
        }
    }
];

// Runtime patterns (omitted full CRUD logic for brevity, only loadRegistry remains)
let runtimePatterns = [];
function loadRegistry() {
  try {
    const data = JSON.parse(fs.readFileSync(REGISTRY_FILE, 'utf-8'));
    // Note: eval is required here to deserialize the function code stored as a string
    runtimePatterns = data.map(p => ({ regex: new RegExp(p.regex), handler: eval('(' + p.handlerCode + ')') }));
  } catch (e) {
    runtimePatterns = [];
  }
}

// Prompt history
function logPromptHistory(prompt, response) {
  try {
      const history = JSON.parse(fs.readFileSync(HISTORY_FILE, 'utf-8'));
      history.push({ prompt, response, timestamp: Date.now() });
      fs.writeFileSync(HISTORY_FILE, JSON.stringify(history.slice(-100), null, 2)); // Keep last 100
  } catch (e) { /* silently ignore history errors */ }
}

// Ollama fallback - This function ensures Ollama "writes all" unhandled requests.
function ollamaQuery(prompt) {
  try {
    const MODEL_NAME = 'llama3';
    
    console.log(`\n\x1b[34m[INFO]\x1b[0m Sending prompt to default model \x1b[33m'${MODEL_NAME}'\x1b[0m...`);
    
    // Using spawnSync for simplicity and synchronous shell execution
    const result = spawnSync(OLLAMA_BIN, ['run', MODEL_NAME, prompt], { encoding: 'utf-8' });
    
    // Capture output
    const response = (result.stdout || '').trim() || (result.stderr || '').trim() || 'No response from Ollama. Ensure the model (llama3) is installed.';
    
    // Log history (simplified history/suggestion logic)
    logPromptHistory(prompt, response);
    
    return { message: response };
  } catch (err) {
    return { message: `${OLLAMA_BIN} execution failed: ${err.message}` };
  }
}

// Plugins loader (simplified for this context)
async function loadPlugins() {
  const plugins = [];
  // Plugin loading logic would go here
  return plugins;
}

// Run prompt
async function runPrompt(prompt) {
  // 1. Check System Patterns (e.g., 'instruct', 'think')
  for (const { regex, handler } of SYSTEM_PATTERNS) {
    const match = prompt.match(regex);
    if (match) return handler({ prompt, match });
  }
  
  // 2. Check Dynamic Runtime Patterns
  loadRegistry();
  for (const { regex, handler } of runtimePatterns) {
    const match = prompt.match(regex);
    if (match) return handler({ prompt, match });
  }
  
  // 3. Check Plugins
  const plugins = await loadPlugins();
  for (const plugin of plugins) {
    try { 
        const result = await plugin({ prompt }); 
        if (result && result.message) return result;
    } catch {}
  }
  
  // 4. FINAL FALLBACK: Let Ollama write all
  return ollamaQuery(prompt);
}

