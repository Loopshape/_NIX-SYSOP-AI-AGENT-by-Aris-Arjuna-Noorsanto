# --- Environment & Configuration ---
export AI_HOME="${AI_HOME:-$HOME/.sysop-ai}"
export ENV_HOME="${ENV_HOME:-$HOME/.sysop_ai_env}"
export NODE_MODULES="$AI_HOME/node_modules"
export PLUGIN_DIR="$AI_HOME/plugins"
export LOG_DIR="$AI_HOME/ollama_logs"
export ORCHESTRATOR_FILE="$AI_HOME/orchestrator.mjs"
export TASKS_DIR="$AI_HOME/tasks"
export PROJECTS_DIR="$AI_HOME/projects"
export DB_DIR="$AI_HOME/db"
export SSH_DIR="$AI_HOME/ssh"
export AI_DATA_DB="$DB_DIR/ai_data.db"
export BLOBS_DB="$DB_DIR/blobs.db"
export WALLET_DB="$DB_DIR/wallet.db"
export SESSION_FILE="$AI_HOME/.session"
export OLLAMA_BIN="ollama"
export NODE_PATH="${NODE_PATH:-}:$NODE_MODULES"

# --- Logging ---
log_event() {
    echo "[\x1b[34m$1\x1b[0m] $(date): $2"
    # Use || true to prevent script exiting if DB is busy during startup
    sqlite3 "$AI_DATA_DB" "INSERT INTO events (event_type, message) VALUES ('$1', '$2');" || true
}

# --- Dependency Checks ---
check_node_modules() {
    if [ ! -d "$NODE_MODULES/sqlite3" ]; then
        echo "[INFO] Node module 'sqlite3' missing. Installing locally..."
        npm install --prefix "$AI_HOME" sqlite3
    fi
}

check_dependencies() {
    local missing_deps=()
    local deps=("sqlite3" "node" "python3" "git" "$OLLAMA_BIN")
    for dep in "${deps[@]}"; do
        if ! command -v "$dep" &> /dev/null; then
            missing_deps+=("$dep")
        fi
    done
    check_node_modules
    if [ ${#missing_deps[@]} -ne 0 ]; then
        echo "Error: Missing dependencies: ${missing_deps[*]}"
        exit 1
    fi
}

# --- Database Initialization ---
init_databases() {
    mkdir -p "$DB_DIR"

    # ai_data.db (Memories and Events)
    sqlite3 "$AI_DATA_DB" <<SQL
CREATE TABLE IF NOT EXISTS memories (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    task_id TEXT,
    prompt TEXT,
    response TEXT,
    proof_state TEXT,
    ts DATETIME DEFAULT CURRENT_TIMESTAMP
);
CREATE TABLE IF NOT EXISTS events (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    event_type TEXT,
    message TEXT,
    ts DATETIME DEFAULT CURRENT_TIMESTAMP
);
SQL

    # blobs.db (Code/File Outputs)
    sqlite3 "$BLOBS_DB" <<SQL
CREATE TABLE IF NOT EXISTS blobs (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    project_name TEXT,
    file_path TEXT,
    content BLOB,
    ts DATETIME DEFAULT CURRENT_TIMESTAMP
);
SQL

    log_event "INFO" "Databases initialized: memories, events, blobs"
}

# --- Setup Orchestrator (Writes the entire Node.js application) ---
setup_orchestrator() {
mkdir -p "$AI_HOME"
cat > "$ORCHESTRATOR_FILE" <<'EOF_JS'
// orchestrator.mjs
import { exec } from 'child_process';
import crypto from 'crypto';
import fs from 'fs';
import path from 'path';
import sqlite3Pkg from 'sqlite3';
const { verbose } = sqlite3Pkg;
const sqlite3 = verbose();

// Inherit ENV vars from bash script
const AI_HOME = process.env.AI_HOME;
const PROJECTS_DIR = process.env.PROJECTS_DIR;
const AI_DATA_DB_PATH = process.env.AI_DATA_DB; 
const BLOBS_DB_PATH = process.env.BLOBS_DB;     
const OLLAMA_BIN = process.env.OLLAMA_BIN || 'ollama';

// Consistent Model Pool (MANDATORY)
const MODEL_POOL = ["core", "2244", "loop", "coin", "code"]; 

// Databases should use the PATH variables from ENV
const aiDataDb = new sqlite3.Database(AI_DATA_DB_PATH);
const blobsDb = new sqlite3.Database(BLOBS_DB_PATH);

/**
 * ProofTracker implements a simple state machine to log task complexity and convergence.
 */
class ProofTracker {
    constructor(initialPrompt) {
        this.cycleIndex = initialPrompt.length;
        this.netWorthIndex = (this.cycleIndex % 128) << 2;
        this.entropyRatio = (this.cycleIndex ^ Date.now()) / 1000;
    }
    crosslineEntropy(data) {
        const hash = crypto.createHash('sha256').update(data).digest('hex');
        this.entropyRatio += parseInt(hash.substring(0, 8), 16);
    }
    proofCycle(converged) {
        this.cycleIndex += converged ? 1 : 0;
        this.netWorthIndex -= converged ? 0 : 1;
    }
    getState() {
        return {
            cycleIndex: this.cycleIndex,
            netWorthIndex: this.netWorthIndex,
            entropyRatio: this.entropyRatio
        };
    }
}

class AIOrchestrator {
    constructor(prompt, options) {
        this.initialPrompt = prompt;
        this.options = options;
        this.taskId = crypto.createHash('sha256').update(Date.now().toString()).digest('hex');
        this.proofTracker = new ProofTracker(prompt);
    }

    /**
     * Executes a single Ollama model asynchronously with robustness checks.
     */
    runOllama(model, currentPrompt) {
        return new Promise((resolve, reject) => {
            console.log(`\n\x1b[34m[INFO]\x1b[0m Model \x1b[33m'${model}'\x1b[0m is thinking...`);
            
            const command = `${OLLAMA_BIN} run ${model} "${currentPrompt.replace(/"/g, '\\"')}"`;
            const child = exec(command);
            let output = '';
            
            // CRITICAL FIX: Handle immediate spawn errors (e.g., OLLAMA_BIN not found)
            child.on('error', (err) => {
                reject(`OLLAMA EXECUTION ERROR: Failed to run model '${model}'. Error: ${err.message}`);
            });
            
            // Stream output to console while capturing for consensus
            child.stdout.on('data', data => {
                process.stdout.write(`\x1b[2m${data}\x1b[0m`);
                output += data;
            });
            child.stderr.on('data', data => process.stderr.write(data));
            
            child.on('close', code => {
                if (code !== 0) return reject(`Model ${model} exited with non-zero code ${code}. Check Ollama logs.`);
                resolve(output.trim());
            });
        });
    }

    /**
     * Runs three consensus loops across the MODEL_POOL.
     */
    async recursiveConsensus() {
        let systemPrompt = `SYSTEM PROMPT: You are a world-class software engineer. Your response MUST be ONLY the requested artifact. Use markdown for all code blocks (e.g., \`\`\`python ... \`\`\`). Do not include any conversational text outside of the code blocks or explanations. User Task:\n`;
        let currentPrompt = systemPrompt + this.initialPrompt;
        let lastFusedOutput = "";
        let converged = false;

        for (let i = 0; i < 3 && !converged; i++) {
            // .catch(e => e) ensures Promise.all always succeeds, converting rejections into resolved values.
            const promises = MODEL_POOL.map(model => this.runOllama(model, currentPrompt).catch(e => e));
            const results = await Promise.all(promises);
            
            // Filter out non-string results (Error objects or error strings)
            const validResults = results.filter(r => typeof r === 'string' && r.length > 0 && !r.startsWith('OLLAMA EXECUTION ERROR'));
            if (validResults.length === 0) return "Error: All models failed to respond or encountered execution errors.";

            this.proofTracker.crosslineEntropy(validResults.join('')); // Update entropy
            
            const fusedOutput = validResults.join('\n---\n').trim();
            if (fusedOutput === lastFusedOutput) {
                converged = true;
                this.proofTracker.proofCycle(true);
            } else {
                this.proofTracker.proofCycle(false);
            }

            lastFusedOutput = fusedOutput;
            // Update the prompt for the next iteration with the output from the last cycle
            currentPrompt = systemPrompt + this.initialPrompt + `\n\n[PREVIOUS ITERATION OUTPUT - Use this to improve the next output]\n${fusedOutput}`;
            this.logEvent('CONSENSUS_LOOP', `Iteration ${i + 1}, Converged: ${converged}`);
        }

        return lastFusedOutput;
    }

    // --- Persistence Methods ---

    getFileExtension(lang) {
      return ({ python: 'py', javascript: 'js', html: 'html', css: 'css', php: 'php', sql: 'sql', bash: 'sh', go: 'go' })[lang] || 'txt';
    }

    saveMemory(prompt, response) {
      aiDataDb.run(
        `INSERT INTO memories (task_id, prompt, response, proof_state) VALUES (?, ?, ?, ?)`,
        [this.taskId, prompt, response, JSON.stringify(this.proofTracker.getState())],
        err => { if (err) console.error('DB Error (memories):', err); }
      );
    }

    saveBlob(project, file, content) {
      blobsDb.run(
        `INSERT INTO blobs (project_name, file_path, content) VALUES (?, ?, ?)`,
        [project, path.basename(file), content],
        err => { if (err) console.error('DB Error (blobs):', err); }
      );
    }

    logEvent(type, msg) {
      aiDataDb.run(
        `INSERT INTO events (event_type, message) VALUES (?, ?)`,
        [type, msg],
        err => { if (err) console.error('DB Error (events):', err); }
      );
    }

    gitCommit(project) {
      const cmd = `git -C ${AI_HOME} add . && git -C ${AI_HOME} commit -m "feat: AI project ${project}"`;
      exec(cmd, (err, stdout, stderr) => {
        if (err) this.logEvent('GIT_ERROR', stderr);
        else this.logEvent('GIT_SUCCESS', `Committed ${project}`);
      });
    }

    parseCodeBlocks(content) {
      const regex = /```(\w+)\s*([\s\S]*?)```/g;
      const blocks = [];
      let match;
      while ((match = regex.exec(content)) !== null) {
        blocks.push({ language: match[1], code: match[2] });
      }
      return blocks;
    }

    async handleCodeGeneration(content) {
      const blocks = this.parseCodeBlocks(content);
      if (!blocks.length) return;

      const project = this.options.project || `task_${this.taskId.substring(0, 8)}`;
      const projectPath = path.join(PROJECTS_DIR, project);
      fs.mkdirSync(projectPath, { recursive: true });

      for (const [i, block] of blocks.entries()) {
        const ext = this.getFileExtension(block.language);
        const filePath = path.join(projectPath, `${block.language}_${i}.${ext}`);
        fs.writeFileSync(filePath, block.code);
        this.saveBlob(project, filePath, block.code);
        console.log(`\x1b[32m[SUCCESS]\x1b[0m Generated file: ${filePath}`);
      }

      this.gitCommit(project);
    }

    async execute() {
        this.logEvent('ORCHESTRATION_START',`Task ${this.taskId} started.`);
        const finalOutput=await this.recursiveConsensus();
        console.log("\n\x1b[1;36m--- Final Consensus Output ---\x1b[0m\n");
        console.log(finalOutput);
        this.saveMemory(this.initialPrompt, finalOutput);
        await this.handleCodeGeneration(finalOutput);
        this.logEvent('ORCHESTRATION_END', `Task ${this.taskId} finished.`);
    }
}

// --- Main Execution ---
(async () => {
    const args = process.argv.slice(2);
    const prompt = args.filter(arg => !arg.startsWith('--')).join(' ');

    const options = Object.fromEntries(
        args.filter(arg => arg.startsWith('--')).map(arg => {
            const parts = arg.slice(2).split('=');
            return [parts[0], parts.length > 1 ? parts.slice(1).join('=') : true];
        })
    );

    if (!prompt) {
        // This case should be handled by the bash script caller, but defensive exit
        process.exit(1);
    }

    const orchestrator = new AIOrchestrator(prompt, options);
    await orchestrator.execute().finally(() => {
        aiDataDb.close();
        blobsDb.close();
    });
})();
EOF_JS

    # No need for chmod +x since it is executed via 'node'
    log_event "INFO" "Orchestrator created at $ORCHESTRATOR_FILE"
}

# --- Run AI Task ---
run_ai_task() {
    local full_prompt="$*"

    # Default logic: if prompt contains a hyphen, use Ollama directly (quick escape)
    if [[ "$full_prompt" == *\-* ]]; then
        echo "[INFO] Hyphen detected; sending directly to Ollama..."
        if command -v "$OLLAMA_BIN" &> /dev/null; then
            "$OLLAMA_BIN" run llama3 "$full_prompt"
        else
            echo "[ERROR] Ollama not found."
        fi
        return
    fi

    # Consensus logic: if no hyphen, use orchestrator
    if [ -f "$SESSION_FILE" ]; then
        local proj=$(cat "$SESSION_FILE")
        full_prompt="$full_prompt --project=$proj"
    fi

    log_event "TASK_START" "Prompt: $full_prompt"
    node "$ORCHESTRATOR_FILE" $full_prompt
    log_event "TASK_END" "Task finished."
}

# --- Status ---
status_check() {
    echo "SysOp-AI Status:"
    echo "AI_HOME: $AI_HOME"
    echo "Ollama: $(command -v $OLLAMA_BIN &>/dev/null && echo 'OK' || echo 'Not Found')"
    echo "SQLite: $(command -v sqlite3 &>/dev/null && echo 'OK' || echo 'Not Found')"
    echo "NodeJS: $(command -v node &>/dev/null && echo 'OK' || echo 'Not Found')"
    echo "Python3: $(command -v python3 &>/dev/null && echo 'OK' || echo 'Not Found')"
    [ -f "$SESSION_FILE" ] && echo "Active Session: $(cat "$SESSION_FILE")" || echo "Active Session: None"
}

# --- Main Script Execution ---
check_dependencies
init_databases
setup_orchestrator # Create/update the orchestrator.mjs file

if [ $# -eq 0 ]; then
    status_check
    exit 0
fi

COMMAND="$1"; shift

case "$COMMAND" in
    --start)
        read -p "Project/Repo name: " proj
        echo "$proj" > "$SESSION_FILE"
        log_event "SESSION" "Started session for $proj"
        ;;
    --stop)
        rm -f "$SESSION_FILE"
        log_event "SESSION" "Stopped session."
        ;;
    run)
        run_ai_task "$@"
        ;;
    status)
        status_check
        ;;
    *)
        run_ai_task "$COMMAND $@"
        ;;
esac
