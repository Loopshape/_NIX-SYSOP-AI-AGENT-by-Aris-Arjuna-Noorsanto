#!/usr/bin/env node

import readline from 'readline';
import path from 'path';

// --- MOCK DATA ---
const MOCK_FILE_CONTENTS = {
    'src/config_setup.py': 'def initialize_engine(): # Setup structures for consensus loop.',
    'src/data_loader.ts': 'const data = loadExternalData("api/v2"); // Validate and transform.',
    'docs/reporting_logic.md': '# Generate final report. Key: cross-reference findings.',
};
const MOCK_URL_CONTENT = 'Simulated API / external content.';
const DEDICATED_MODELS = ['loop', '2244', 'code', 'core', 'coin'];

// --- UTILITIES ---

function assignModel(filePath) {
    if (filePath.endsWith('.py') || filePath.endsWith('.ts')) return 'code';
    if (filePath.endsWith('.md')) return 'coin';
    if (filePath.includes('config') || filePath.includes('setup')) return 'core';
    if (filePath.includes('data')) return '2244';
    return 'loop';
}

function getLabelColor(label) {
    const hash = label.split('').reduce((acc, c) => acc + c.charCodeAt(0), 0);
    return `\x1b[1;${31 + (hash % 6)}m`;
}

// --- TERMINAL MANAGER (PRIORITY OUTPUT HANDLER) ---

/**
 * Manages cursor positioning and output drawing to ensure the REPL prompt
 * is never overwritten and remains stable during concurrent batch streaming.
 */
class TerminalManager {
    constructor(dashboardLines) {
        this.dashboardLines = dashboardLines;
        // The readline interface is primarily used to manage prompt drawing
        this.rl = readline.createInterface({
            input: process.stdin,
            output: process.stdout,
            prompt: '\x1b[1;33mYou >\x1b[0m '
        });
    }

    /** Clears the current line. */
    clearLine() {
        readline.cursorTo(process.stdout, 0);
        readline.clearLine(process.stdout, 0);
    }

    /** Moves the cursor to the top dashboard region. */
    moveToDashboard() {
        readline.cursorTo(process.stdout, 0);
        // Move up by the height of the dashboard + 1 (for the blank line below it)
        readline.moveCursor(process.stdout, 0, -(this.dashboardLines + 1));
    }

    /** Moves the cursor back down past the dashboard region. */
    movePastDashboard() {
        readline.moveCursor(process.stdout, 0, this.dashboardLines + 1);
        readline.cursorTo(process.stdout, 0);
    }

    /** Redraws the REPL prompt cleanly. */
    redrawPrompt() {
        this.rl.prompt(true);
    }

    /**
     * Writes streaming output (token by token) safely. This is the critical
     * method used by both batch and dialog streams to ensure the prompt is 
     * protected after every write.
     * @param {string} data - The content to write.
     * @param {boolean} isNewline - Whether this write includes a final newline.
     */
    writeStream(data, isNewline = false) {
        this.clearLine(); // Clear the current prompt/input line
        process.stdout.write(data);
        if (isNewline) process.stdout.write('\n');
        this.redrawPrompt(); // Redraw the prompt at the bottom
    }
}

// --- MOCK STREAMING BACKEND ---

/**
 * Simulates a token-by-token streaming response from a model using the TM.
 * @param {string} model - The model name.
 * @param {string} prompt - The input prompt.
 * @param {string} prefix - The color-coded prefix for the output line.
 * @param {TerminalManager} tm - The terminal manager instance.
 */
async function streamBackendResponse(model, prompt, prefix = '', tm) {
    const response = `(MOCK:${model}) Processing: ${prompt.substring(0, 50)}...`;
    const tokens = response.split(/(\s+)/).filter(t => t.length > 0);
    
    // Write prefix once
    tm.writeStream(prefix);

    for (const token of tokens) {
        // Write each token without a newline to stream on the same line
        tm.writeStream(token, false);
        await new Promise(r => setTimeout(r, 10 + Math.random() * 5));
    }
    
    // Finish with a final newline for the stream line
    tm.writeStream('', true); 
}

// --- META-CONSENSUS BATCH ENGINE ---

class MetaConsensusEngine {
    constructor(files, maxIter, tm) {
        this.files = files;
        this.maxIterations = maxIter;
        this.tm = tm;
        this.states = {};
        this.fusedOutput = '';
        this.lastSignature = '';
        this.currentIter = 0;
        this.isComplete = false;

        this.dashboardLines = files.length + 3;
        files.forEach(f => this.initState(f));
    }

    initState(f) {
        this.states[f] = { progress: 0, entropy: Math.random() * 100, influence: 0.6 + Math.random() * 0.4, output: '', model: assignModel(f) };
    }

    updateState(f) {
        const s = this.states[f];
        s.progress = Math.min(1, s.progress + 0.05 + Math.random() * 0.05);
        s.entropy = Math.max(0, s.entropy - (s.influence * 15 * Math.random() * 0.1));
        s.influence = Math.min(1, s.influence + (Math.random() - 0.4) * 0.005);
    }

    /** Draws the dashboard safely at the top of the terminal. */
    _drawDashboard(converged = false) {
        this.tm.moveToDashboard();

        const status = this.isComplete ? 'COMPLETE' : (converged ? 'CONVERGED' : 'RUNNING'),
              color = this.isComplete ? '\x1b[47m\x1b[30m' : (converged ? '\x1b[42m' : '\x1b[44m');

        let out = `${color}| META-CONSENSUS DASHBOARD | ITER:${this.currentIter}/${this.maxIterations} STATUS:${status} | Sig:${this.lastSignature.substring(0, 10)}...\x1b[0m\n`;
        out += '|--------------------------------------------------------------------------------\n';

        for (const f of this.files) {
            const s = this.states[f];
            const c = getLabelColor(f), base = path.basename(f).padEnd(20), mod = s.model.toUpperCase().padEnd(6);
            const p = (s.progress * 100).toFixed(0).padStart(3);
            const ebar = '█'.repeat(Math.floor(s.entropy / 10)).padEnd(10);
            const ibar = '▒'.repeat(Math.floor(s.influence * 10)).padEnd(10);

            out += `| ${c}${base}\x1b[0m (${mod}) | PROG:${p}% | ENT:[\x1b[33m${ebar}\x1b[0m] | INF:[\x1b[35m${ibar}\x1b[0m]\n`;
        }
        out += '|--------------------------------------------------------------------------------';

        // Write line by line to prevent flicker and manage cursor
        const lines = out.split('\n');
        for (let i = 0; i < this.dashboardLines; i++) {
            readline.cursorTo(process.stdout, 0);
            readline.clearLine(process.stdout, 0);
            if (i < lines.length) process.stdout.write(lines[i]);
            if (i < this.dashboardLines - 1) process.stdout.write('\n');
        }

        // Return cursor control to the main stream area
        this.tm.movePastDashboard();
        this.tm.redrawPrompt();
    }

    fuseOutputs() {
        const out = this.files.map(f => Array(Math.max(1, Math.floor(this.states[f].influence * 3))).fill(this.states[f].output).join('\n'));
        this.fusedOutput = out.join('\n--- FUSED ---\n').trim();
    }

    getSignature(o) { return o.substring(0, 100); }

    async processFile(f, prevFusion) {
        const s = this.states[f], model = s.model, prompt = `[${model}] Analyze ${f} entropy:${s.entropy.toFixed(1)} prevFusion:${prevFusion.substring(0, 30)}...`;
        
        const prefix = `${getLabelColor(f)}[R${this.currentIter}|${path.basename(f)}]\x1b[0m > `;

        this.tm.writeStream(`\n\x1b[90m--- Batch Processing ${path.basename(f)} ---\x1b[0m\n`, true);

        for (let i = 0; i < 3; i++) {
            this.updateState(f);
            await new Promise(r => setTimeout(r, 10)); // Short pause for dashboard update

            // Stream batch tokens using the TM
            await streamBackendResponse(model, prompt, prefix, this.tm);
            s.output += `(Batch-Token-${i}) `;
        }
        this.tm.writeStream(`\x1b[90m--- End ${path.basename(f)} ---\x1b[0m\n`, true);
    }

    /** Main loop, runs as a continuous non-blocking process. */
    async run() {
        // Continuous dashboard update loop (runs even when not processing files)
        const dashboardLoop = setInterval(() => {
            this._drawDashboard(this.lastSignature.length > 0 && !this.isComplete);
        }, 100); // Fast update for smooth UI

        for (let iter = 1; iter <= this.maxIterations; iter++) {
            this.currentIter = iter;
            this.tm.writeStream(`\n\x1b[1;37m--- META ITERATION ${iter} STARTED ---\x1b[0m\n`, true);
            
            const prevFusion = this.fusedOutput;

            // Process all files concurrently
            await Promise.all(this.files.map(f => this.processFile(f, prevFusion)));

            this.fuseOutputs();
            const sig = this.getSignature(this.fusedOutput);

            if (this.lastSignature && sig === this.lastSignature) {
                this.isComplete = true;
                this.tm.writeStream(`\n\x1b[32m[CONVERGED]\x1b[0m Iteration ${iter}\n`, true);
                break;
            }
            this.lastSignature = sig;

            this.tm.writeStream(`\n\x1b[1;32m[FUSED OUTPUT Sig:${sig.substring(0, 10)}...]\x1b[0m\n`, true);
            this.tm.writeStream(this.fusedOutput.substring(0, 300) + '...\n', true);
        }

        // Cleanup
        clearInterval(dashboardLoop);
        this.isComplete = true;
        this._drawDashboard(true);
        this.tm.writeStream(`\n\x1b[1;36m[Consensus Complete]\x1b[0m Max iterations reached.\n`, true);
        this.tm.redrawPrompt();
    }
}

// --- HYBRID MODE ORCHESTRATOR ---

async function startHybridMode(files, models, iterations) {
    const filePaths = Object.keys(MOCK_FILE_CONTENTS);
    const dashboardLines = filePaths.length + 3;
    const tm = new TerminalManager(dashboardLines);

    // Reserve space and draw initial prompt
    for (let i = 0; i < dashboardLines + 1; i++) {
        process.stdout.write('\n');
    }
    tm.redrawPrompt();

    const engine = new MetaConsensusEngine(filePaths, iterations, tm);

    // 1. Start batch process in background
    const batchPromise = engine.run();

    // 2. Setup REPL interaction
    tm.rl.on('line', async (line) => {
        const prompt = line.trim();
        if (prompt.toLowerCase() === 'exit') {
            tm.rl.close();
            return;
        }
        if (!prompt) {
            tm.redrawPrompt();
            return;
        }

        if (engine.isComplete) {
            tm.writeStream('\n\x1b[33m[WARN]\x1b[0m Batch process is complete. Dialog fusion ended.\n', true);
            tm.redrawPrompt();
            return;
        }

        tm.writeStream(`\n\x1b[1;37m--- INTERACTIVE QUERY ---\x1b[0m\n`, true);

        // Stream models concurrently using the TM
        await Promise.all(models.map(async model => {
            const prefix = `${getLabelColor(model)}[DIALOG|${model}]\x1b[0m > `;
            await streamBackendResponse(model, prompt, prefix, tm);
        }));

        tm.writeStream(`\x1b[1;37m--- END QUERY ---\x1b[0m\n`, true);
        tm.redrawPrompt();
    });

    tm.rl.on('close', () => {
        tm.clearLine();
        console.log('\n\x1b[1;36m[CLI Session]\x1b[0m Ended.');
        process.exit(0);
    });

    // Wait for the batch process to finish
    await batchPromise;
}

// --- CLI ENTRY POINT ---

function printUsage() {
    console.log(`\n\x1b[1;37mUsage:\x1b[0m`);
    console.log(`  \x1b[1;36mnode cli.js hybrid [flags]\x1b[0m  - Runs batch consensus and interactive dialog concurrently.`);
    console.log(`\n\x1b[1;37mFlags (for hybrid mode):\x1b[0m`);
    console.log(`  \x1b[35m--models=<name1,name2>\x1b[0m Comma-separated list of models for dialog (default: core,loop).`);
    console.log(`  \x1b[35m--iterations=<N>\x1b[0m     Max convergence iterations for batch (default: 6).`);
    console.log(`\nExample:`);
    console.log(`  node cli.js hybrid --models=core,code --iterations=4`);
}

async function main() {
    const args = process.argv.slice(2);
    const cmd = args[0];

    const flags = {};
    args.slice(1).forEach(a => {
        if (a.startsWith('--')) {
            const [k, v] = a.slice(2).split('=');
            flags[k] = v === undefined ? true : v;
        }
    });

    if (cmd === 'hybrid') {
        const models = flags.models ? flags.models.split(',') : ['core', 'loop'];
        const iterations = flags.iterations ? parseInt(flags.iterations) : 6;

        if (isNaN(iterations) || iterations <= 0) {
            console.error(`\x1b[31m[ERROR]\x1b[0m --iterations must be a positive integer.`);
            return;
        }

        await startHybridMode(Object.keys(MOCK_FILE_CONTENTS), models, iterations);
    } else {
        console.error(`\x1b[31m[ERROR]\x1b[0m Unknown command or mode specified: '${cmd}'`);
        printUsage();
    }
}

main();