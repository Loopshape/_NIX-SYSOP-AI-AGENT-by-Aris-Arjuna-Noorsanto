# Check for Node module 'sqlite3' and install if missing (non-repetitive)
check_node_modules() {
    if [ ! -d "$NODE_MODULES/sqlite3" ]; then
        echo "[INFO] Node module 'sqlite3' missing. Installing locally to $AI_HOME..."
        npm install --prefix "$AI_HOME" sqlite3
    fi
}

# Check all required dependencies
check_dependencies() {
    local missing_deps=()
    local deps=("sqlite3" "node" "python3" "git" "$OLLAMA_BIN")
    for dep in "${deps[@]}"; do
        if ! command -v "$dep" &> /dev/null; then
            missing_deps+=("$dep")
        fi
    done
    
    # Run Node module check, but don't fail if it's slow
    check_node_modules
    
    if [ ${#missing_deps[@]} -ne 0 ]; then
        echo "Error: Missing required CLI dependencies: ${missing_deps[*]}. Please install them and try again."
        exit 1
    fi
}

