// Note: Consolidated model pool for simplicity in this version.
const MODEL_POOL = ["phi3", "llama3", "codegemma"];

const aiDataDb = new sqlite3.Database(AI_DATA_DB_PATH);
const blobsDb = new sqlite3.Database(BLOBS_DB_PATH);

/**
 * ProofTracker implements the S:I:R (Stability:Interaction:Resonance) dynamic state.
 * Stability (NetWorthIndex) controls the convergence threshold.
 * Interaction/Resonance (EntropyRatio) controls the model generation temperature.
 */
class ProofTracker {
    constructor(initialPrompt) {
        // Stability based on complexity/length (S)
        this.cycleIndex = initialPrompt.length;
        this.netWorthIndex = (this.cycleIndex % 128) << 2;
        // Initial entropy based on prompt and time (I:R)
        this.entropyRatio = (this.cycleIndex ^ Date.now()) / 1000;
    }
    
    /** Updates entropy based on hash of fused output (Interaction/Resonance). */
    crosslineEntropy(data) {
        const hash = crypto.createHash('sha256').update(data).digest('hex');
        // Add a portion of the hash to increase entropy on divergence
        this.entropyRatio += parseInt(hash.substring(0, 8), 16) / 1000000;
    }

    /** Updates Stability (NetWorthIndex) based on convergence. */
    proofCycle(converged) {
        this.cycleIndex += converged ? 1 : 0;
        // Stability decreases if no convergence (loss of coherence)
        this.netWorthIndex -= converged ? 0 : 1;
        this.netWorthIndex = Math.max(0, this.netWorthIndex); // Prevent negative stability
    }
    
    getState() { return { cycleIndex: this.cycleIndex, netWorthIndex: this.netWorthIndex, entropyRatio: this.entropyRatio }; }

    getDynamicTemperature() {
        const { entropyRatio } = this.getState();
        // Normalization: Map entropy to a safe temperature range [0.3, 0.9].
        const normalizedEntropy = Math.min(1, entropyRatio / 50000);
        let dynamicTemp = 0.3 + (normalizedEntropy * 0.6);
        return Math.min(0.95, Math.max(0.05, dynamicTemp));
    }

    getDynamicConvergenceThreshold() {
        const { netWorthIndex } = this.getState();
        const initialIndex = this.cycleIndex; 
        const maxNetWorthIndex = (initialIndex % 128) << 2;
        
        // Normalize the current stability index against its initial potential max.
        const normalizedIndex = Math.min(1, Math.max(0, netWorthIndex / (maxNetWorthIndex || 1)));
        
        // Dynamic range: Base threshold of 50 chars + up to 50 more based on stability.
        const dynamicThreshold = 50 + (normalizedIndex * 50);
        
        return Math.floor(dynamicThreshold);
    }
}


class AIOrchestrator {
    constructor(prompt, options) {
        this.initialPrompt = prompt;
        this.options = options;
        this.taskId = crypto.createHash('sha256').update(Date.now().toString()).digest('hex').substring(0, 16);
        this.proofTracker = new ProofTracker(prompt);
    }

    runOllama(model, currentPrompt, temperature) {
        return new Promise((resolve, reject) => {
            // Note: Ollama CLI doesn't easily support dynamic temperature via 'run' command line args.
            // For production, this should be replaced with the Ollama REST API call.
            console.log(`\n\x1b[34m[INFO]\x1b[0m Model \x1b[33m'${model}'\x1b[0m is thinking (Temp: ${temperature.toFixed(2)})...`);
            
            // Using exec for simplicity, but the temperature parameter is ignored here for now 
            // due to Ollama CLI limitations. A REST API call is required for full S:I:R control.
            const child = exec(`${OLLAMA_BIN} run ${model} "${currentPrompt.replace(/"/g, '\\"')}"`);
            let output = '';
            
            child.stdout.on('data', (data) => {
                process.stdout.write(`\x1b[2m${data}\x1b[0m`);
                output += data;
            });
            child.stderr.on('data', (data) => process.stderr.write(data));
            child.on('close', (code) => {
                if (code !== 0) return reject(`Model ${model} exited with code ${code}`);
                resolve(output.trim());
            });
        });
    }

    async recursiveConsensus() {
        let systemPrompt = `SYSTEM PROMPT: You are a world-class software engineer. Your response MUST be ONLY the requested artifact. Use markdown for all code blocks (e.g., \`\`\`python ... \`\`\`). Do not include any conversational text outside of the code blocks or explanations. User Task:\n`;
        let currentPrompt = systemPrompt + this.initialPrompt;
        let lastFusedOutput = "";
        let converged = false;
        
        // Use 5 iterations max
        for (let i = 0; i < 5 && !converged; i++) {
            const dynamicTemp = this.proofTracker.getDynamicTemperature();
            const dynamicThreshold = this.proofTracker.getDynamicConvergenceThreshold();

            const promises = MODEL_POOL.map(model => 
                this.runOllama(model, currentPrompt, dynamicTemp).catch(e => {
                    console.error(`\x1b[31m[ERROR]\x1b[0m ${e}`);
                    return ""; 
                })
            );
            const results = await Promise.all(promises);
            const validResults = results.filter(r => typeof r === 'string' && r.length > 0);
            
            if (validResults.length === 0) return "Error: All models failed to respond.";
            
            // Fusion logic: simple concatenation for proof of work
            const fusedOutput = validResults.join('\n---\n').trim();
            
            // Check for convergence using the dynamic threshold
            const lastPrefix = lastFusedOutput.substring(0, dynamicThreshold);
            const currentPrefix = fusedOutput.substring(0, dynamicThreshold);

            if (lastPrefix === currentPrefix && i > 0) {
                converged = true;
                this.proofTracker.proofCycle(true);
            } else {
                this.proofTracker.proofCycle(false);
            }
            
            this.proofTracker.crosslineEntropy(fusedOutput);

            lastFusedOutput = fusedOutput;
            currentPrompt = systemPrompt + this.initialPrompt + `\n\n[PREVIOUS ITERATION OUTPUT]\n${fusedOutput}`;
            this.logEvent('CONSENSUS_LOOP', `Iteration ${i + 1}, Converged: ${converged}, Temp: ${dynamicTemp.toFixed(2)}, Threshold: ${dynamicThreshold}`);
        }
        return lastFusedOutput;
    }

    parseCodeBlocks(content) {
        return [...content.matchAll(/```(\w+)\s*([\s\S]*?)```/g)].map(match => ({
            language: match[1].toLowerCase(),
            code: match[2].trim(),
        }));
    }

    async handleCodeGeneration(content) {
        const blocks = this.parseCodeBlocks(content);
        if (blocks.length === 0) return;
        
        const projectName = this.options.project || `task_${this.taskId.substring(0, 8)}`;
        const projectPath = path.join(PROJECTS_DIR, projectName);
        fs.mkdirSync(projectPath, { recursive: true });

        for (const [i, block] of blocks.entries()) {
            const ext = this.getFileExtension(block.language);
            const fileName = `${block.language}_${i}.${ext}`;
            const filePath = path.join(projectPath, fileName);
            fs.writeFileSync(filePath, block.code);
            this.saveBlob(projectName, filePath, block.code);
            console.log(`\x1b[32m[SUCCESS]\x1b[0m Generated file: ${filePath}`);
        }
        this.gitCommit(projectName);
    }
    
    getFileExtension(lang) { return ({ python: 'py', javascript: 'js', html: 'html', css: 'css', php: 'php', sql: 'sql', bash: 'sh', go: 'go', markdown: 'md' })[lang] || 'txt'; }
    
    saveMemory(prompt, response) {
        const proofState = JSON.stringify(this.proofTracker.getState());
        aiDataDb.run("INSERT INTO memories (task_id, prompt, response, proof_state) VALUES (?, ?, ?, ?)", [this.taskId, prompt, response, proofState], (err) => {
            if (err) console.error("Database Error (Memory):", err.message);
        });
    }

    saveBlob(proj, file, content) { 
        blobsDb.run("INSERT INTO blobs (project_name, file_path, content) VALUES (?, ?, ?)", [proj, path.basename(file), content], (err) => {
            if (err) console.error("Database Error (Blob):", err.message);
        });
    }
    
    logEvent(type, msg) { 
        aiDataDb.run("INSERT INTO events (event_type, message) VALUES (?, ?)", [type, msg], (err) => {
             if (err) console.error("Database Error (Event):", err.message);
        });
    }

    gitCommit(projectName) {
        exec(`git -C ${AI_HOME} add . && git -C ${AI_HOME} commit -m "feat: AI project ${projectName}"`, (err, stdout, stderr) => {
            if (err) this.logEvent('GIT_ERROR', `Failed to commit ${projectName}: ${stderr}`);
            else this.logEvent('GIT_SUCCESS', `Committed project ${projectName}`);
        });
    }

    async execute() {
        this.logEvent('ORCHESTRATION_START', `Task ${this.taskId} started.`);
        const finalOutput = await this.recursiveConsensus();
        console.log("\n\x1b[1;36m--- Final Consensus Output ---\x1b[0m\n");
        console.log(finalOutput);
        this.saveMemory(this.initialPrompt, finalOutput);
        await this.handleCodeGeneration(finalOutput);
        this.logEvent('ORCHESTRATION_END', `Task ${this.taskId} finished.`);
    }
}

// --- Main Execution ---
(async () => {
    const args = process.argv.slice(2);
    // Find prompt arguments (not starting with --) and join them
    const prompt = args.filter(arg => !arg.startsWith('--')).join(' '); 
    // Parse options (like --project=name)
    const options = Object.fromEntries(args.filter(arg => arg.startsWith('--')).map(arg => arg.slice(2).split('=')));
    
    if (!prompt) {
        console.error("\x1b[31mError:\x1b[0m No prompt or command provided to orchestrator.");
        process.exit(1);
    }

    const orchestrator = new AIOrchestrator(prompt, options);
    await orchestrator.execute().finally(() => {
        // Ensure databases are closed after the task completes
        aiDataDb.close();
        blobsDb.close();
    });
})();
