# Helper function to run the orchestrator with session check
run_ai_task() {
    local full_prompt="$*"

    # 1. Hyphen Check: If prompt contains a hyphen, route directly to Ollama
    if [[ "$full_prompt" == *\-* ]]; then
        echo "[INFO] Prompt contains a hyphen ('$full_prompt'). Bypassing orchestrator and sending directly to Ollama."
        if command -v "$OLLAMA_BIN" &> /dev/null; then
            # Run Ollama directly
            "$OLLAMA_BIN" run llama3 "$full_prompt"
        else
            echo "[ERROR] Ollama command not found. Cannot execute hyphenated prompt directly."
        fi
        return
    fi

    # 2. Non-Hyphenated Prompt: Route to Orchestrator (.mjs)
    local prompt="$full_prompt"

    # Append project flag if session is active
    if [ -f "$SESSION_FILE" ]; then
        local proj_name=$(cat "$SESSION_FILE")
        prompt="$prompt --project=$proj_name"
    fi

    log_event "TASK_START" "Prompt: $prompt"
    # Ensure the orchestrator file exists before running
    if [ ! -f "$ORCHESTRATOR_FILE" ]; then
        log_event "ERROR" "Orchestrator file not found. Run 'ai status' or 'ai setup'."
        return
    fi

    # Execute the Node.js orchestrator
    node "$ORCHESTRATOR_FILE" "$prompt"
    log_event "TASK_END" "Task finished."
}


# --- Command Functions ---

# Manage SSH Keys
manage_ssh() {
    case "$1" in
        ls) ls -la "$SSH_DIR" ;;
        gen)
            read -p "Enter key name (e.g., id_rsa_project): " key_name
            ssh-keygen -t rsa -b 4096 -f "$SSH_DIR/$key_name"
            log_event "SSH" "Generated new key: $key_name"
            ;;
        *) echo "Usage: ai ssh-key [ls|gen]" ;;
    esac
}


# --- Main Execution ---
check_dependencies
setup_environment

# If no arguments, show status as the default action
if [ $# -eq 0 ]; then
    status_check
    exit 0
fi

COMMAND="$1"
shift

case "$COMMAND" in
    --start)
        read -p "Enter project/repo name: " proj_name
        echo "$proj_name" > "$SESSION_FILE"
        log_event "SESSION" "Started session for project '$proj_name'"
        ;;
    --stop)
        rm -f "$SESSION_FILE"
        log_event "SESSION" "Stopped session."
        ;;
    run)
        run_ai_task "$@"
        ;;
    import)
        URL="$1"
        CONTENT=$(curl -sL "$URL")
        log_event "IMPORT" "Importing content from $URL"
        echo "Import complete. Summarizing the content..."
        run_ai_task "Summarize and analyze the following content: $CONTENT"
        ;;
    memories) sqlite3 -header -column "$AI_DATA_DB" "SELECT id, task_id, substr(prompt, 1, 40) as prompt, ts FROM memories ORDER BY ts DESC;" ;;
    events) sqlite3 -header -column "$AI_DATA_DB" "SELECT * FROM events ORDER BY ts DESC;" ;;
    blobs) sqlite3 -header -column "$BLOBS_DB" "SELECT id, project_name, file_path, length(content) as size, ts FROM blobs ORDER BY ts DESC;" ;;
    ssh-key) manage_ssh "$@" ;;
    seed) python3 "$AI_HOME/manager.py" seed "$@" ;;
    wallet) python3 "$AI_HOME/manager.py" wallet "$@" ;;
    server) python3 "$AI_HOME/manager.py" server & ;;
    status) status_check ;;
    --help|-h) show_help ;;
    *) # Default to 'run' if no other command matches
        # $COMMAND is the first word of the prompt, and $@ is the rest.
        run_ai_task "$COMMAND $@"
        ;;
esac