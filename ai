#!/usr/bin/env bash
set -euo pipefail

# ───────────────────────────────
# NIX-SYSOP-AI-AGENT Full Bash Orchestrator
# ───────────────────────────────
export AI_HOME="${AI_HOME:-$HOME/.sysop-ai}"
export NODE_MODULES="$AI_HOME/node_modules"
export ORCHESTRATOR_FILE="$AI_HOME/orchestrator.mjs"
export PROJECTS_DIR="$AI_HOME/projects"
export TASKS_DIR="$AI_HOME/tasks"
export DB_DIR="$AI_HOME/db"
export LOG_DIR="$AI_HOME/logs"
export SESSION_FILE="$AI_HOME/.session"
export OLLAMA_BIN="ollama"

mkdir -p "$AI_HOME" "$PROJECTS_DIR" "$TASKS_DIR" "$DB_DIR" "$LOG_DIR"

log_event() {
    echo -e "[\033[34m$1\033[0m] $(date): $2"
    sqlite3 "$DB_DIR/ai_data.db" "INSERT INTO events (event_type, message) VALUES ('$1', '$2');" || true
}

status_check() {
    echo "AI_HOME: $AI_HOME"
    echo "Ollama: $(command -v $OLLAMA_BIN &>/dev/null && echo OK || echo Not Found)"
    echo "NodeJS: $(command -v node &>/dev/null && echo OK || echo Not Found)"
    echo "SQLite: $(command -v sqlite3 &>/dev/null && echo OK || echo Not Found)"
    [ -f "$SESSION_FILE" ] && echo "Active Session: $(cat "$SESSION_FILE")" || echo "Active Session: None"
}

check_dependencies() {
    local deps=("node" "npm" "sqlite3" "$OLLAMA_BIN")
    local missing=()
    for dep in "${deps[@]}"; do
        command -v "$dep" >/dev/null 2>&1 || missing+=("$dep")
    done
    if [ ${#missing[@]} -gt 0 ]; then
        echo "Missing dependencies: ${missing[*]}"
        exit 1
    fi
}

setup_node_modules() {
    if [ ! -d "$NODE_MODULES" ]; then
        log_event "INFO" "Installing Node dependencies..."
        npm install --prefix "$AI_HOME"
    fi
}

start_session() {
    local proj_name="$1"
    echo "$proj_name" > "$SESSION_FILE"
    log_event "SESSION" "Started session: $proj_name"
}

stop_session() {
    rm -f "$SESSION_FILE"
    log_event "SESSION" "Stopped session."
}

run_ai_task() {
    local prompt="$*"
    if [[ "$prompt" == *-* ]]; then
        log_event "TASK" "Running direct Ollama task: $prompt"
        "$OLLAMA_BIN" run llama3 "$prompt"
        return
    fi
    [ -f "$SESSION_FILE" ] && prompt="$prompt --project=$(cat $SESSION_FILE)"
    log_event "TASK_START" "$prompt"

    if [ ! -f "$ORCHESTRATOR_FILE" ]; then
        log_event "ERROR" "Orchestrator file missing: $ORCHESTRATOR_FILE"
        return
    fi

    node "$ORCHESTRATOR_FILE" $prompt
    log_event "TASK_END" "$prompt"
}

manage_ssh() {
    mkdir -p "$AI_HOME/ssh"
    case "$1" in
        ls) ls -la "$AI_HOME/ssh" ;;
        gen)
            read -p "Key name: " key_name
            ssh-keygen -t rsa -b 4096 -f "$AI_HOME/ssh/$key_name"
            log_event "SSH" "Generated key: $key_name"
            ;;
        *) echo "Usage: ai ssh-key [ls|gen]" ;;
    esac
}

setup_orchestrator() {
mkdir -p "$AI_HOME"
cat > "$ORCHESTRATOR_FILE" <<'EOF'
// orchestrator.mjs
import { exec } from 'child_process';
import crypto from 'crypto';
import fs from 'fs';
import path from 'path';
import sqlite3Pkg from 'sqlite3';
const { verbose } = sqlite3Pkg;
const sqlite3 = verbose();

const AI_HOME = process.env.AI_HOME;
const PROJECTS_DIR = process.env.PROJECTS_DIR;
const DB_DIR = process.env.DB_DIR;
const OLLAMA_BIN = process.env.OLLAMA_BIN || 'ollama';
const MODEL_POOL = ["core", "loop", "code"];
const aiDataDb = new sqlite3.Database(path.join(DB_DIR, "ai_data.db"));
const blobsDb = new sqlite3.Database(path.join(DB_DIR, "blobs.db"));

class ProofTracker {
    constructor(initialPrompt) {
        this.cycleIndex = initialPrompt.length;
        this.netWorthIndex = (this.cycleIndex % 128) << 2;
        this.entropyRatio = (this.cycleIndex ^ Date.now()) / 1000;
    }
    crosslineEntropy(data) {
        const hash = crypto.createHash('sha256').update(data).digest('hex');
        this.entropyRatio += parseInt(hash.substring(0, 8), 16);
    }
    proofCycle(converged) {
        this.cycleIndex += converged ? 1 : 0;
        this.netWorthIndex -= converged ? 0 : 1;
    }
    getState() {
        return { cycleIndex: this.cycleIndex, netWorthIndex: this.netWorthIndex, entropyRatio: this.entropyRatio };
    }
}

class AIOrchestrator {
    constructor(prompt, options) {
        this.initialPrompt = prompt;
        this.options = options;
        this.taskId = crypto.createHash('sha256').update(Date.now().toString()).digest('hex');
        this.proofTracker = new ProofTracker(prompt);
    }
    runOllama(model, currentPrompt) {
        return new Promise((resolve, reject) => {
            console.log(`\n\x1b[34m[INFO]\x1b[0m Model \x1b[33m'${model}'\x1b[0m is thinking...`);
            const child = exec(`${OLLAMA_BIN} run ${model} "${currentPrompt.replace(/"/g, '\\"')}"`);
            let output = '';
            child.stdout.on('data', data => { process.stdout.write(`\x1b[2m${data}\x1b[0m`); output += data; });
            child.stderr.on('data', data => process.stderr.write(data));
            child.on('close', code => { if (code!==0) return reject(`Model ${model} exited with code ${code}`); resolve(output.trim()); });
        });
    }
    async recursiveConsensus() {
        let systemPrompt = `SYSTEM PROMPT: You are a world-class software engineer. Only return requested artifacts.\nUser Task:\n`;
        let currentPrompt = systemPrompt + this.initialPrompt;
        let lastFusedOutput = "";
        let converged = false;
        for (let i=0;i<3 && !converged;i++) {
            const promises = MODEL_POOL.map(m=>this.runOllama(m,currentPrompt).catch(e=>e));
            const results = await Promise.all(promises);
            const validResults = results.filter(r=>typeof r==='string'&&r.length>0);
            if(validResults.length===0) return "Error: All models failed.";
            const fusedOutput = validResults.join('\n---\n').trim();
            if(fusedOutput===lastFusedOutput){ converged=true; this.proofTracker.proofCycle(true); } else { this.proofTracker.proofCycle(false); }
            lastFusedOutput = fusedOutput;
            currentPrompt = systemPrompt + this.initialPrompt + `\n\n[PREVIOUS OUTPUT]\n${fusedOutput}`;
            this.logEvent('CONSENSUS_LOOP',`Iteration ${i+1}, Converged: ${converged}`);
        }
        return lastFusedOutput;
    }
    parseCodeBlocks(content){ return [...content.matchAll(/```(\w+)\s*([\s\S]*?)```/g)].map(m=>({language:m[1].toLowerCase(),code:m[2].trim()})); }
    async handleCodeGeneration(content){
        const blocks=this.parseCodeBlocks(content);
        if(blocks.length===0) return;
        const projectName=this.options.project||`task_${this.taskId.substring(0,8)}`;
        const projectPath=path.join(PROJECTS_DIR,projectName);
        fs.mkdirSync(projectPath,{recursive:true});
        for(const [i,block] of blocks.entries()){
            const ext=this.getFileExtension(block.language);
            const fileName=`${block.language}_${i}.${ext}`;
            const filePath=path.join(projectPath,fileName);
            fs.writeFileSync(filePath,block.code);
            this.saveBlob(projectName,filePath,block.code);
            console.log(`\x1b[32m[SUCCESS]\x1b[0m Generated file: ${filePath}`);
        }
        this.gitCommit(projectName);
    }
    getFileExtension(lang){ return ({python:'py',javascript:'js',html:'html',css:'css',php:'php',sql:'sql',bash:'sh',go:'go'})[lang]||'txt'; }
    saveMemory(prompt,response){ const proofState=JSON.stringify(this.proofTracker.getState()); aiDataDb.run("INSERT INTO memories (task_id,prompt,response,proof_state) VALUES (?,?,?,?)",[this.taskId,prompt,response,proofState]); }
    saveBlob(proj,file,content){ blobsDb.run("INSERT INTO blobs (project_name,file_path,content) VALUES (?,?,?)",[proj,path.basename(file),content]); }
    logEvent(type,msg){ aiDataDb.run("INSERT INTO events (event_type,message) VALUES (?,?)",[type,msg]); }
    gitCommit(projectName){ exec(`git -C ${AI_HOME} add . && git -C ${AI_HOME} commit -m "feat: AI project ${projectName}"`,(err,stdout,stderr)=>{ if(err)this.logEvent('GIT_ERROR',`Failed to commit ${projectName}: ${stderr}`); else this.logEvent('GIT_SUCCESS',`Committed project ${projectName}`); }); }
    async execute(){
        this.logEvent('ORCHESTRATION_START',`Task ${this.taskId} started.`);
        const finalOutput=await this.recursiveConsensus();
        console.log("\n\x1b[1;36m--- Final Consensus Output ---\x1b[0m\n");
        console.log(finalOutput);
        this.saveMemory(this.initialPrompt,finalOutput);
        await this.handleCodeGeneration(finalOutput);
        this.logEvent('ORCHESTRATION_END',`Task ${this.taskId} finished.`);
    }
}

(async()=>{
    const args=process.argv.slice(2);
    const prompt=args.filter(a=>!a.startsWith('--')).join(' ');
    const options=Object.fromEntries(args.filter(a=>a.startsWith('--')).map(a=>{ const p=a.slice(2).split('='); return [p[0],p.length>1?p.slice(1).join('='):true]; }));
    if(!prompt) process.exit(1);
    const orchestrator=new AIOrchestrator(prompt,options);
    await orchestrator.execute().finally(()=>{ aiDataDb.close(); blobsDb.close(); });
})();
EOF
log_event "INFO" "Created full orchestrator file at $ORCHESTRATOR_FILE"
}

show_help() {
cat <<EOF
SysOp-AI Bash Orchestrator
Usage: ai <command> [args]

Commands:
  run <prompt>         Run AI task via orchestrator
  --start <name>       Start project session
  --stop               Stop current session
  ssh-key [ls|gen]     Manage SSH keys
  status               Show environment and dependency status
  --help               Show this help
EOF
}

# --- Initialize ---
check_dependencies
setup_node_modules
setup_orchestrator

# --- CLI Routing ---
if [ $# -eq 0 ]; then status_check; exit 0; fi
COMMAND="$1"; shift
case "$COMMAND" in
    --start) start_session "$1" ;;
    --stop) stop_session ;;
    run) run_ai_task "$@" ;;
    ssh-key) manage_ssh "$@" ;;
    status) status_check ;;
    --help|-h) show_help ;;
    *) run_ai_task "$COMMAND $*" ;;
esac
