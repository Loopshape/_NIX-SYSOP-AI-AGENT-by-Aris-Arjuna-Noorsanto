#!/usr/bin/env bash
#
# SysOp-AI: A Self-Contained AI Command-Line Application
#
# This script provides a framework for interacting with a pool of local language
# models via Ollama to perform tasks, generate code, and persist its state.
#
# USAGE:
#   sysop-ai.sh <command> [options]
#
# COMMANDS:
#   run <prompt>      Runs the main AI loop with a given prompt.
#   import <url...>   Imports content from one or more URLs.
#   memories          Lists the AI's past interactions.
#   events            Shows the detailed event log.
#   blobs             Lists all files stored in the blob database.
#   status            Displays configuration and environment status.
#   help              Shows this help message.
#
# See 'sysop-ai.sh <command> --help' for more information on a specific command.
#
set -euo pipefail
IFS=$'\n\t'

# ==============================================================================
# SECTION 1: CORE AI ENGINE & HELPERS
# ==============================================================================

# -------------------- Paths --------------------
AI_HOME="${AI_HOME:-$HOME/.sysop_ai_env}"
AI_DB="$AI_HOME/ai_data.db"
BLOBS_DB="$AI_HOME/blobs.db"
TASKS_DIR="$AI_HOME/tasks"
PROJECTS_DIR="$AI_HOME/projects"
OLLAMA_BIN="${OLLAMA_BIN:-/home/linuxbrew/.linuxbrew/bin/ollama}"

# -------------------- Models --------------------
# All models participate in the recursive consensus pool
declare -A MODEL_WEIGHTS
POOL_MODELS=("2244:latest" "core:latest" "loop:latest" "coin:latest" "code:latest" "sqlcoder:latest" "php:latest")
MODEL_WEIGHTS=( ["2244:latest"]=2 ["core:latest"]=2 ["loop:latest"]=1 ["coin:latest"]=1 ["code:latest"]=2 ["sqlcoder:latest"]=3 ["php:latest"]=2 )

# -------------------- Core Initializer --------------------
_initialize_env() {
    mkdir -p "$AI_HOME" "$TASKS_DIR" "$PROJECTS_DIR"
    
    # Initialize main AI database
    sqlite3 "$AI_DB" <<'EOF'
CREATE TABLE IF NOT EXISTS memories (
    id INTEGER PRIMARY KEY, timestamp DATETIME DEFAULT CURRENT_TIMESTAMP,
    prompt TEXT, response TEXT, task_id TEXT
);
CREATE TABLE IF NOT EXISTS events (
    id INTEGER PRIMARY KEY, timestamp DATETIME DEFAULT CURRENT_TIMESTAMP,
    event_hash TEXT UNIQUE, event_data TEXT
);
CREATE TABLE IF NOT EXISTS projects (
    id INTEGER PRIMARY KEY, created_at DATETIME DEFAULT CURRENT_TIMESTAMP,
    name TEXT, description TEXT, type TEXT, files TEXT
);
EOF
    
    # Initialize BLOB storage database
    sqlite3 "$BLOBS_DB" <<'EOF'
CREATE TABLE IF NOT EXISTS blobs (
    id INTEGER PRIMARY KEY, created_at DATETIME DEFAULT CURRENT_TIMESTAMP,
    filename TEXT, content TEXT, project_id INTEGER
);
CREATE TABLE IF NOT EXISTS schemas (
    id INTEGER PRIMARY KEY, created_at DATETIME DEFAULT CURRENT_TIMESTAMP,
    name TEXT, schema_type TEXT, definition TEXT
);
EOF
}

# -------------------- Git Setup --------------------
_git_setup() {
    local git_branch="devel"
    if ! git -C "$AI_HOME" rev-parse --is-inside-work-tree &>/dev/null; then
        git init -b "$git_branch" "$AI_HOME"
        echo "[Git] Initialized new repository in $AI_HOME"
    fi
    git -C "$AI_HOME" checkout "$git_branch" 2>/dev/null || git -C "$AI_HOME" checkout -b "$git_branch"
}

# -------------------- SQL Safety and Helpers --------------------
# Function to safely escape single quotes for SQLite insertion
escape_sql_string() {
    # Replace single quote (') with two single quotes ('')
    echo "$1" | sed "s/'/''/g"
}

# Generates a unique task ID
gen_task_id() { echo -n "${1:-}$(date +%s%N)$RANDOM" | sha256sum | cut -c1-16; }

# Generates a 6-part XOR tag based on content hash
xor_modulo_tag() { 
    local text="$1"
    printf "%d" "0x$(echo -n "$text" | sha256sum | cut -c1-8)"; 
}

# Inserts a prompt/response pair into the memories table (SQL Safe)
add_memory() { 
    local safe_prompt=$(escape_sql_string "$1")
    local safe_response=$(escape_sql_string "$2")
    local task_id="$3"
    local tag=$(( $(xor_modulo_tag "$1$2") % 6 ))
    sqlite3 "$AI_DB" "INSERT INTO memories (prompt,response,task_id) VALUES ('$safe_prompt','[XOR$tag] $safe_response','$task_id');" 
}

# Inserts an event into the audit log (SQL Safe)
add_event() { 
    local event="$1"
    local hash=$(echo -n "$event" | sha256sum | cut -c1-64)
    local safe_event=$(escape_sql_string "$event")
    sqlite3 "$AI_DB" "INSERT OR IGNORE INTO events (event_hash,event_data) VALUES ('$hash','$safe_event');" 
}

# Inserts file content into the blob database (SQL Safe)
add_blob() { 
    local safe_filename=$(escape_sql_string "$1")
    local safe_content=$(escape_sql_string "$2")
    local project_id="${3:-}"
    if [[ -n "$project_id" ]]; then
        sqlite3 "$BLOBS_DB" "INSERT INTO blobs (filename,content,project_id) VALUES ('$safe_filename','$safe_content','$project_id');"
    else
        sqlite3 "$BLOBS_DB" "INSERT INTO blobs (filename,content) VALUES ('$safe_filename','$safe_content');"
    fi
}

# Stores a database schema
add_schema() {
    local safe_name=$(escape_sql_string "$1")
    local safe_type=$(escape_sql_string "$2")
    local safe_definition=$(escape_sql_string "$3")
    sqlite3 "$BLOBS_DB" "INSERT INTO schemas (name,schema_type,definition) VALUES ('$safe_name','$safe_type','$safe_definition');"
}

# Executes the Ollama model with JSON formatting
run_ollama_json() { 
    # NOTE: Does not check for model availability to avoid cluttering the core loop, 
    # but relies on the user ensuring models are installed.
    "$OLLAMA_BIN" run "$1" --format=json --keepalive=3200m "$2"
}

# -------------------- Syntax Highlight --------------------
highlight_file() {
    local file="$1"
    if command -v pygmentize &>/dev/null; then
        echo "--- FILE PREVIEW: $file (Highlighted) ---"
        pygmentize -g "$file"
    else
        echo "--- FILE PREVIEW: $file (Plain Text) ---"
        cat "$file"
    fi
}

# -------------------- Database Schema Management --------------------
manage_schema() {
    local operation="$1"
    local schema_name="$2"
    local schema_type="$3"
    local definition="${4:-}"
    
    case "$operation" in
        "create")
            if [[ -z "$definition" ]]; then
                echo "Error: Schema definition required for create operation" >&2
                return 1
            fi
            add_schema "$schema_name" "$schema_type" "$definition"
            echo "[Schema] Created schema: $schema_name ($schema_type)"
            ;;
        "get")
            local result
            result=$(sqlite3 "$BLOBS_DB" "SELECT definition FROM schemas WHERE name='$schema_name' AND schema_type='$schema_type' ORDER BY id DESC LIMIT 1;")
            if [[ -n "$result" ]]; then
                echo "$result"
            else
                echo "Error: Schema not found: $schema_name ($schema_type)" >&2
                return 1
            fi
            ;;
        "list")
            sqlite3 -header -column "$BLOBS_DB" "SELECT name, schema_type, created_at FROM schemas ORDER BY created_at DESC;"
            ;;
    esac
}

# -------------------- Project Management --------------------
create_project() {
    local project_name="$1"
    local project_type="$2"
    local description="$3"
    local safe_name=$(escape_sql_string "$project_name")
    local safe_type=$(escape_sql_string "$project_type")
    local safe_desc=$(escape_sql_string "$description")
    
    sqlite3 "$AI_DB" "INSERT INTO projects (name, description, type) VALUES ('$safe_name', '$safe_desc', '$safe_type');"
    local project_id=$(sqlite3 "$AI_DB" "SELECT last_insert_rowid();")
    
    mkdir -p "$PROJECTS_DIR/$project_name"
    echo "$project_id"
}

add_file_to_project() {
    local project_id="$1"
    local filename="$2"
    local content="$3"
    
    add_blob "$filename" "$content" "$project_id"
    
    # Update project files list
    local current_files=$(sqlite3 "$AI_DB" "SELECT files FROM projects WHERE id=$project_id;")
    local updated_files="$current_files$filename,"
    sqlite3 "$AI_DB" "UPDATE projects SET files='$updated_files' WHERE id=$project_id;"
}

# -------------------- Code Validation Helpers --------------------
validate_php() {
    local file="$1"
    if command -v php &>/dev/null; then
        if php -l "$file" &>/dev/null; then
            echo "[PHP] Syntax valid: $file"
            return 0
        else
            echo "[PHP] Syntax error in: $file" >&2
            return 1
        fi
    else
        echo "[PHP] Warning: php command not available, skipping validation"
        return 0
    fi
}

validate_sql() {
    local file="$1"
    if command -v sqlite3 &>/dev/null; then
        # Create temporary database to validate SQL syntax
        local temp_db=$(mktemp)
        if sqlite3 "$temp_db" < "$file" 2>/dev/null; then
            echo "[SQL] Syntax valid: $file"
            rm -f "$temp_db"
            return 0
        else
            echo "[SQL] Syntax error in: $file" >&2
            rm -f "$temp_db"
            return 1
        fi
    else
        echo "[SQL] Warning: sqlite3 not available, skipping validation"
        return 0
    fi
}

validate_go() {
    local file="$1"
    if command -v go &>/dev/null; then
        if go fmt "$file" &>/dev/null && go vet "$file" 2>/dev/null; then
            echo "[Go] Syntax valid: $file"
            return 0
        else
            echo "[Go] Syntax/style issues in: $file" >&2
            return 1
        fi
    else
        echo "[Go] Warning: go command not available, skipping validation"
        return 0
    fi
}

validate_nodejs() {
    local file="$1"
    if command -v node &>/dev/null; then
        if node -c "$file" &>/dev/null; then
            echo "[Node.js] Syntax valid: $file"
            return 0
        else
            echo "[Node.js] Syntax error in: $file" >&2
            return 1
        fi
    else
        echo "[Node.js] Warning: node command not available, skipping validation"
        return 0
    fi
}

validate_python() {
    local file="$1"
    if command -v python3 &>/dev/null; then
        if python3 -m py_compile "$file" &>/dev/null; then
            echo "[Python] Syntax valid: $file"
            rm -f "${file}c"  # Remove compiled bytecode
            return 0
        else
            echo "[Python] Syntax error in: $file" >&2
            rm -f "${file}c"
            return 1
        fi
    else
        echo "[Python] Warning: python3 not available, skipping validation"
        return 0
    fi
}

validate_bash() {
    local file="$1"
    if command -v bash &>/dev/null; then
        if bash -n "$file" &>/dev/null; then
            echo "[Bash] Syntax valid: $file"
            return 0
        else
            echo "[Bash] Syntax error in: $file" >&2
            return 1
        fi
    else
        echo "[Bash] Warning: bash not available, skipping validation"
        return 0
    fi
}

# -------------------- Recursive Consensus Engine --------------------
# Attempts to reach a stable state (convergence) over multiple model iterations.
iterate_models_recursive() {
    local -n models="$1"
    local -n weights="$2"
    local prompt="$3"
    local max_iter="${4:-5}" # Default to 5 iterations
    local prev_output=""
    local iter=1
    
    echo "--- Initiating Recursive Consensus (Max Iter: $max_iter) ---"
    while (( iter <= max_iter )); do
        local current_prompt="$prompt"$'\n'"[PREVIOUS ITERATION OUTPUT]$prev_output"
        local fused_output=""
        
        for model in "${models[@]}"; do
            local json vote data
            
            # Ollama call: feeds the full prompt + previous output
            if ! json=$(run_ollama_json "$model" "$current_prompt"); then 
                add_event "[WARN] Model $model failed in Iteration $iter."
                continue 
            fi
            
            # Output is considered a 'yes' vote if it contains data
            vote=$(echo "$json" | jq -r '.vote // "data_present"')
            data=$(echo "$json" | jq -r '.data // ""')
            
            if [[ -n "$data" ]]; then
                fused_output+="[MODEL $model RESULT] $data"$'\n'
            fi
        done
        
        # Check for Convergence
        if [[ "$fused_output" == "$prev_output" ]]; then 
            add_event "[Converged] Recursive consensus stabilized at Iter $iter."
            echo "[Converged at Iter $iter]"
            break 
        fi
        
        # Update context for next iteration
        add_event "[Iter $iter] Output length: ${#fused_output}. Continuing."
        prev_output="$fused_output"
        iter=$((iter + 1))
    done
    
    echo "$prev_output"
}

# -------------------- Multi-Language File Generation --------------------
generate_multi_file_project() {
    local project_type="$1"
    local task_id="$2"
    local content="$3"
    local project_name="project_${task_id}"
    local project_dir="$PROJECTS_DIR/$project_name"
    
    mkdir -p "$project_dir"
    
    case "$project_type" in
        "fullstack_web")
            echo "[Project] Generating full-stack web application..."
            
            # HTML file
            echo "$content" | grep -A 100 "<!-- HTML -->" | sed '1d' > "$project_dir/index.html"
            add_file_to_project "$project_id" "index.html" "$(cat "$project_dir/index.html")"
            
            # CSS file
            echo "$content" | grep -A 100 "/* CSS */" | sed '1d' > "$project_dir/style.css"
            add_file_to_project "$project_id" "style.css" "$(cat "$project_dir/style.css")"
            
            # JavaScript file
            echo "$content" | grep -A 100 "// JavaScript" | sed '1d' > "$project_dir/app.js"
            add_file_to_project "$project_id" "app.js" "$(cat "$project_dir/app.js")"
            
            # PHP backend
            echo "$content" | grep -A 100 "<?php" | sed '1d' > "$project_dir/api.php"
            add_file_to_project "$project_id" "api.php" "$(cat "$project_dir/api.php")"
            validate_php "$project_dir/api.php"
            ;;
            
        "data_pipeline")
            echo "[Project] Generating data pipeline..."
            
            # Python ETL script
            echo "$content" | grep -A 100 "# Python" | sed '1d' > "$project_dir/etl.py"
            add_file_to_project "$project_id" "etl.py" "$(cat "$project_dir/etl.py")"
            validate_python "$project_dir/etl.py"
            
            # SQL schema
            echo "$content" | grep -A 100 "-- SQL" | sed '1d' > "$project_dir/schema.sql"
            add_file_to_project "$project_id" "schema.sql" "$(cat "$project_dir/schema.sql")"
            validate_sql "$project_dir/schema.sql"
            
            # Go service
            echo "$content" | grep -A 100 "// Go" | sed '1d' > "$project_dir/service.go"
            add_file_to_project "$project_id" "service.go" "$(cat "$project_dir/service.go")"
            validate_go "$project_dir/service.go"
            ;;
            
        "microservices")
            echo "[Project] Generating microservices architecture..."
            
            # Node.js service
            echo "$content" | grep -A 100 "// Node.js" | sed '1d' > "$project_dir/user-service.js"
            add_file_to_project "$project_id" "user-service.js" "$(cat "$project_dir/user-service.js")"
            validate_nodejs "$project_dir/user-service.js"
            
            # Go service
            echo "$content" | grep -A 100 "// Go Service" | sed '1d' > "$project_dir/auth-service.go"
            add_file_to_project "$project_id" "auth-service.go" "$(cat "$project_dir/auth-service.go")"
            validate_go "$project_dir/auth-service.go"
            
            # Python service
            echo "$content" | grep -A 100 "# Python Service" | sed '1d' > "$project_dir/data-service.py"
            add_file_to_project "$project_id" "data-service.py" "$(cat "$project_dir/data-service.py")"
            validate_python "$project_dir/data-service.py"
            
            # Docker compose
            echo "$content" | grep -A 100 "# Docker" | sed '1d' > "$project_dir/docker-compose.yml"
            add_file_to_project "$project_id" "docker-compose.yml" "$(cat "$project_dir/docker-compose.yml")"
            ;;
    esac
    
    echo "$project_dir"
}

# -------------------- AI Loop (The 'run' command's core) --------------------
run_ai_loop() {
    local prompt="$1"
    # These flags are passed via global scope from _cmd_run
    local FORCE_EDIT="${FORCE_EDIT:-false}"
    local CREATE_PROJECT="${CREATE_PROJECT:-false}"
    local PROJECT_TYPE="${PROJECT_TYPE:-fullstack_web}"
    local -a IMPORT_URLS=("${IMPORT_URLS[@]:-}")

    local task_id
    task_id=$(gen_task_id "$prompt")
    local current_context="$prompt"
    local MAX_LOOPS=7
    local project_id=""

    # Import URLs and inject content into context before starting
    if [[ ${#IMPORT_URLS[@]} -gt 0 ]]; then
        echo "[Task Setup] Importing external content..."
        for url in "${IMPORT_URLS[@]}"; do
            # The import command handles adding the content to blobs
            _cmd_import "$url"
            # Get content from the latest blob entry and add it to context
            local content
            content=$(sqlite3 "$BLOBS_DB" "SELECT content FROM blobs ORDER BY id DESC LIMIT 1;")
            current_context+=$'\n'"[IMPORTED URL CONTENT: $url] $content"$'\n'
        done
    fi

    # Create project if requested
    if [[ "$CREATE_PROJECT" == true ]]; then
        project_id=$(create_project "project_$task_id" "$PROJECT_TYPE" "AI-generated project for task: $prompt")
        echo "[Project] Created project with ID: $project_id"
    fi

    echo "--- Starting AI Task (Task ID: $task_id) ---"

    for ((i=1;i<=MAX_LOOPS;i++)); do
        echo -e "\n[AI LOOP $i/$MAX_LOOPS]"
        
        # 1. Run Recursive Consensus
        local consensus_output
        consensus_output=$(iterate_models_recursive POOL_MODELS MODEL_WEIGHTS "$current_context" 5)
        
        # Log the output
        add_memory "$current_context" "$consensus_output" "$task_id"
        add_event "[AI LOOP $i] Consensus output generated."
        
        echo "[Consensus Result]"
        echo "$consensus_output"

        # 2. Check for File Generation Directive
        local file_type="default_html_triad"
        local main_content="$consensus_output"
        local base_filename="$TASKS_DIR/task_${task_id}"
        local primary_file_path=""

        # Check if the output starts with GENERATE_FILE:
        if [[ "$consensus_output" =~ ^GENERATE_FILE: ]]; then
            # Extract file type (e.g., bash_script, python_script, html_single)
            file_type=$(echo "$consensus_output" | sed -n 's/^GENERATE_FILE:\([^[:space:]]*\).*$/\1/p')
            # Extract content by removing the directive line
            main_content=$(echo "$consensus_output" | sed '1d') 
            echo "[Directive] Detected file type: $file_type"
        fi

        # 3. Handle File Creation
        if [[ "$FORCE_EDIT" == true ]] || [[ "$consensus_output" =~ "GENERATE_CODE" ]] || [[ "$file_type" != "default_html_triad" ]]; then
            
            case "$file_type" in
                bash_script)
                    primary_file_path="${base_filename}.sh"
                    echo "#!/bin/bash"$'\n'"$main_content" > "$primary_file_path"
                    chmod +x "$primary_file_path"
                    validate_bash "$primary_file_path"
                    echo "[Files Saved] Bash Script: $primary_file_path"
                    ;;
                python_script)
                    primary_file_path="${base_filename}.py"
                    echo "#!/usr/bin/env python3"$'\n'"$main_content" > "$primary_file_path"
                    chmod +x "$primary_file_path"
                    validate_python "$primary_file_path"
                    echo "[Files Saved] Python Script: $primary_file_path"
                    ;;
                php_script)
                    primary_file_path="${base_filename}.php"
                    echo "<?php"$'\n'"$main_content"$'\n'"?>" > "$primary_file_path"
                    validate_php "$primary_file_path"
                    echo "[Files Saved] PHP Script: $primary_file_path"
                    ;;
                sql_schema)
                    primary_file_path="${base_filename}.sql"
                    echo "$main_content" > "$primary_file_path"
                    validate_sql "$primary_file_path"
                    manage_schema "create" "schema_$task_id" "database" "$main_content"
                    echo "[Files Saved] SQL Schema: $primary_file_path"
                    ;;
                go_program)
                    primary_file_path="${base_filename}.go"
                    echo "package main"$'\n'"$main_content" > "$primary_file_path"
                    validate_go "$primary_file_path"
                    echo "[Files Saved] Go Program: $primary_file_path"
                    ;;
                nodejs_script)
                    primary_file_path="${base_filename}.js"
                    echo "#!/usr/bin/env node"$'\n'"$main_content" > "$primary_file_path"
                    chmod +x "$primary_file_path"
                    validate_nodejs "$primary_file_path"
                    echo "[Files Saved] Node.js Script: $primary_file_path"
                    ;;
                html_single)
                    primary_file_path="${base_filename}.html"
                    echo "<!DOCTYPE html>"$'\n'"<html lang='en'>"$'\n'"$main_content"$'\n'"</html>" > "$primary_file_path"
                    echo "[Files Saved] Single HTML File: $primary_file_path"
                    ;;
                css_style)
                    primary_file_path="${base_filename}.css"
                    echo "/* CSS3 Styles */"$'\n'"$main_content" > "$primary_file_path"
                    echo "[Files Saved] CSS3 Stylesheet: $primary_file_path"
                    ;;
                javascript_module)
                    primary_file_path="${base_filename}.js"
                    echo "// ES6+ JavaScript Module"$'\n'"$main_content" > "$primary_file_path"
                    validate_nodejs "$primary_file_path"
                    echo "[Files Saved] JavaScript Module: $primary_file_path"
                    ;;
                fullstack_web|data_pipeline|microservices)
                    if [[ -n "$project_id" ]]; then
                        local project_dir
                        project_dir=$(generate_multi_file_project "$file_type" "$task_id" "$main_content")
                        echo "[Project] Generated multi-file project in: $project_dir"
                        primary_file_path="$project_dir"
                    else
                        echo "[WARN] Project generation requested but no project created. Use --project flag." >&2
                    fi
                    ;;
                *) # Default: separate HTML, JS, CSS triad (For backward compatibility/web tasks)
                    primary_file_path="${base_filename}.html"
                    echo "<!-- HTML5 generated by AI -->"$'\n'"<!DOCTYPE html>"$'\n'"<html lang='en'>"$'\n'"<head><meta charset='UTF-8'><title>AI Generated</title></head>"$'\n'"<body>$main_content</body></html>" > "$primary_file_path"
                    
                    local js_path="${base_filename}.js"
                    local css_path="${base_filename}.css"
                    
                    echo "// ES6+ JavaScript generated by AI" > "$js_path"
                    echo "/* CSS3 generated by AI */" > "$css_path"
                    
                    add_blob "$js_path" "// JS generated by AI"
                    add_blob "$css_path" "/* CSS generated by AI */"
                    git -C "$AI_HOME" add "$js_path" "$css_path"
                    echo "[Files Saved] HTML5, JS, CSS3 triad."
                    ;;
            esac
            
            # 4. Persistence and Version Control
            if [[ -n "$primary_file_path" && "$primary_file_path" != *project_* ]]; then
                add_blob "$primary_file_path" "$(cat "$primary_file_path")"
                git -C "$AI_HOME" add "$primary_file_path"
                git -C "$AI_HOME" commit -m "AI loop $i for task $task_id ($file_type)" || true
                echo "[Git] Committed changes."
                highlight_file "$primary_file_path"
            elif [[ -n "$primary_file_path" && -d "$primary_file_path" ]]; then
                git -C "$AI_HOME" add "$primary_file_path"
                git -C "$AI_HOME" commit -m "AI project generation for task $task_id ($file_type)" || true
                echo "[Git] Committed project files."
            fi
            
            # 5. Break loop after file generation (assumed final output)
            break
        fi

        # 6. Update Context and Continue
        current_context+=$'\n'"$consensus_output"
        
        # Check for FINAL_ANSWER directive
        if [[ "$consensus_output" =~ "FINAL_ANSWER" ]]; then
            echo "--- FINAL ANSWER REACHED ---"
            break
        fi
        
    done
}


# ==============================================================================
# SECTION 2: CLI COMMANDS & DISPATCHER
# ==============================================================================

_show_help() {
    # Extracts help text from the script's header comments
    grep '^#' "$0" | cut -c 3-
    echo ""
    echo "SUPPORTED FILE TYPES:"
    echo "  bash_script, python_script, php_script, sql_schema, go_program"
    echo "  nodejs_script, html_single, css_style, javascript_module"
    echo "  fullstack_web, data_pipeline, microservices"
    echo ""
    echo "PROJECT TYPES:"
    echo "  fullstack_web    - HTML5/CSS3/JS/PHP full stack application"
    echo "  data_pipeline    - Python/SQL/Go data processing pipeline"
    echo "  microservices    - Node.js/Go/Python microservices architecture"
}

_cmd_run() {
    local PROMPT=""
    # Global variables used by run_ai_loop
    FORCE_EDIT=false
    CREATE_PROJECT=false
    PROJECT_TYPE="fullstack_web"
    declare -a IMPORT_URLS=()

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --force) FORCE_EDIT=true; shift ;;
            --project) 
                CREATE_PROJECT=true
                if [[ -n "$2" && ! "$2" =~ ^- ]]; then 
                    PROJECT_TYPE="$2"; shift 2
                else
                    shift
                fi
                ;;
            --import) 
                if [[ -z "$2" ]]; then echo "Error: --import requires a URL." >&2; exit 1; fi
                IMPORT_URLS+=("$2"); shift 2 ;;
            --help)
                echo "Usage: sysop-ai.sh run <prompt> [options]"
                echo "Options:"
                echo "  --force          Force file generation (default to HTML triad)."
                echo "  --project [type] Create a multi-file project of specified type."
                echo "  --import <url>   Import a URL's content into the context before running."
                echo ""
                echo "Project Types: fullstack_web, data_pipeline, microservices"
                exit 0
                ;;
            *) PROMPT="$*"; break ;;
        esac
    done

    if [[ -z "$PROMPT" ]]; then
        echo "Error: 'run' command requires a prompt." >&2
        _show_help >&2
        exit 1
    fi

    run_ai_loop "$PROMPT"
}

_cmd_import() {
    if [[ $# -eq 0 ]]; then
        echo "Error: 'import' command requires at least one URL." >&2
        exit 1
    fi
    for url in "$@"; do
        echo "[Importing URL] $url"
        local filename
        filename="$TASKS_DIR/$(basename "$url" | sed 's/[^a-zA-Z0-9._-]/_/g')"
        local content
        
        # Use curl to fetch content
        if ! content=$(curl -sL "$url"); then
             echo "[ERROR] Failed to fetch content from $url." >&2
             continue
        fi

        echo "$content" > "$filename"
        add_blob "$filename" "$content"
        echo "[Imported and saved to blobs] $filename"
    done
}

_cmd_memories() {
    echo "--- AI Memory Log (Last 20) ---"
    sqlite3 -header -column "$AI_DB" \
        "SELECT id, timestamp, task_id, substr(prompt, 1, 60) AS prompt FROM memories ORDER BY id DESC LIMIT 20;"
}

_cmd_events() {
    echo "--- AI Event Log (Last 20) ---"
    sqlite3 -header -column "$AI_DB" \
        "SELECT id, timestamp, event_data FROM events ORDER BY id DESC LIMIT 20;"
}

_cmd_blobs() {
    echo "--- Stored Blobs ---"
    sqlite3 -header -column "$BLOBS_DB" \
        "SELECT id, created_at, filename, substr(content, 1, 50) AS content_preview FROM blobs ORDER BY id DESC;"
}

_cmd_schemas() {
    echo "--- Database Schemas ---"
    manage_schema "list"
}

_cmd_status() {
    echo "--- SysOp-AI Status ---"
    echo "AI_HOME:      $AI_HOME"
    echo "AI_DB:        $AI_DB"
    echo "BLOBS_DB:     $BLOBS_DB"
    echo "TASKS_DIR:    $TASKS_DIR"
    echo "PROJECTS_DIR: $PROJECTS_DIR"
    echo "OLLAMA_BIN:   $OLLAMA_BIN"
    if ! command -v "$OLLAMA_BIN" &>/dev/null; then
        echo "Ollama Status: Not found or not executable at the specified path."
    else
        echo "Ollama Status: Found."
    fi
    echo "Configured Models (for Recursive Consensus):"
    for model in "${POOL_MODELS[@]}"; do
        echo "  - $model (Weight: ${MODEL_WEIGHTS[$model]:-1})"
    done
    echo ""
    echo "Validation Tools:"
    command -v php &>/dev/null && echo "  PHP: Available" || echo "  PHP: Not found"
    command -v sqlite3 &>/dev/null && echo "  SQLite: Available" || echo "  SQLite: Not found"
    command -v go &>/dev/null && echo "  Go: Available" || echo "  Go: Not found"
    command -v node &>/dev/null && echo "  Node.js: Available" || echo "  Node.js: Not found"
    command -v python3 &>/dev/null && echo "  Python3: Available" || echo "  Python3: Not found"
    command -v bash &>/dev/null && echo "  Bash: Available" || echo "  Bash: Not found"
}

# --- Main Command Dispatcher ---
_main() {
    if [[ $# -eq 0 ]]; then
        _show_help
        exit 1
    fi

    local command="$1"
    shift

    # Ensure environment is ready before running any command
    _initialize_env
    _git_setup

    case "$command" in
        run) _cmd_run "$@" ;;
        import) _cmd_import "$@" ;;
        memories) _cmd_memories "$@" ;;
        events) _cmd_events "$@" ;;
        blobs) _cmd_blobs "$@" ;;
        schemas) _cmd_schemas "$@" ;;
        status) _cmd_status "$@" ;;
        help|--help|-h) _show_help ;;
        *)
            echo "Error: Unknown command '$command'" >&2
            _show_help >&2
            exit 1
            ;;
    esac
}

# Execute the main function with all script arguments
_main "$@"
